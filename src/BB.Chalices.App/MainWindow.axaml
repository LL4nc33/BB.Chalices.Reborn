<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BB.Chalices.ViewModels"
        x:Class="BB.Chalices.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1240" Height="720" MinWidth="1100" MinHeight="640"
        RequestedThemeVariant="Dark"
        FontFamily="{DynamicResource GothicFont}"
        Background="{DynamicResource BgBase}"
        Title="BB Chalices">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Blood}" BorderThickness="0,0,0,2" Padding="24,16">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Chalice Dungeon Editor" FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource Parchment}" />
                    <TextBlock FontSize="14" Foreground="{DynamicResource BloodBright}"
                               Text="{Binding CharacterName, StringFormat='Hunter — {0}'}"
                               IsVisible="{Binding HasLoadedSave}" />
                    <TextBlock FontSize="14" Foreground="{DynamicResource ParchmentDim}"
                               Text="No save loaded" IsVisible="{Binding !HasLoadedSave}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Content="Open Save…" Click="OnOpenSaveClick" />
                    <Button Content="Save" Command="{Binding SaveCommand}" IsEnabled="{Binding HasLoadedSave}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="16" ColumnDefinitions="300,12,*,12,400">

            <!-- Column 1: saves + slots -->
            <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*">
                <Border Grid.Row="0" Background="{DynamicResource BgPanel}"
                        BorderBrush="{DynamicResource Edge}" BorderThickness="1" Padding="14">
                    <StackPanel Spacing="8">
                        <TextBlock Text="shadPS4 saves" FontSize="15" Foreground="{DynamicResource Parchment}" />
                        <Button Content="Detect saves" Command="{Binding DetectSavesCommand}" HorizontalAlignment="Stretch" />
                        <ListBox ItemsSource="{Binding DetectedSaves}" SelectedItem="{Binding SelectedDetectedSave}"
                                 MaxHeight="110" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DetectedSaveViewModel">
                                    <StackPanel Margin="2">
                                        <TextBlock Text="{Binding FileName}" Foreground="{DynamicResource Parchment}" />
                                        <TextBlock Text="{Binding Location}" FontSize="11" Foreground="{DynamicResource ParchmentDim}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="1" Text="Altar slots" FontSize="15"
                           Foreground="{DynamicResource Parchment}" Margin="2,16,0,8" />

                <ListBox Grid.Row="2" ItemsSource="{Binding Slots}" SelectedItem="{Binding SelectedSlot}"
                         Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource Edge}" BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SlotViewModel">
                            <Grid ColumnDefinitions="Auto,*" Margin="2,4">
                                <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,10,0"
                                         VerticalAlignment="Center" Fill="{DynamicResource Blood}"
                                         IsVisible="{Binding Occupied}" />
                                <StackPanel Grid.Column="1">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="15"
                                                   Foreground="{DynamicResource Parchment}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Headline}" FontSize="13"
                                                   Foreground="{DynamicResource ParchmentDim}" VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Text="{Binding Detail}" FontSize="11" Foreground="{DynamicResource BloodBright}"
                                               IsVisible="{Binding Occupied}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Column 2: dungeon catalogue -->
            <Border Grid.Column="2" Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource Edge}" BorderThickness="1" Padding="16">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0" ColumnDefinitions="*,170" Margin="0,0,0,12">
                        <TextBox Grid.Column="0" Text="{Binding SearchText}"
                                 PlaceholderText="Search glyphs or descriptions…" Margin="0,0,8,0" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}" HorizontalAlignment="Stretch" />
                    </Grid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Dungeons}" SelectedItem="{Binding SelectedDungeon}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:DungeonViewModel">
                                <StackPanel Spacing="2" Margin="2">
                                    <TextBlock Text="{Binding Glyph}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Parchment}" />
                                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{DynamicResource BloodBright}" />
                                    <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap"
                                               Foreground="{DynamicResource ParchmentDim}"
                                               IsVisible="{Binding Description, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Grid.Row="2" Content="Place in selected slot" Command="{Binding ApplyDungeonCommand}"
                            HorizontalAlignment="Stretch" Margin="0,12,0,0" />
                </Grid>
            </Border>

            <!-- Column 3: headstone editor -->
            <Border Grid.Column="4" Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource Edge}" BorderThickness="1" Padding="16">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">
                    <TextBlock Grid.Row="0" Text="Selected slot" FontSize="15" Foreground="{DynamicResource Parchment}" />
                    <TextBlock Grid.Row="1" Text="{Binding SelectedSlotType}" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource BloodBright}" Margin="0,2,0,14" />

                    <StackPanel Grid.Row="2" Spacing="4" Margin="0,0,0,12">
                        <TextBlock Text="Rites" FontSize="13" Foreground="{DynamicResource ParchmentDim}" Margin="0,0,0,2" />
                        <ItemsControl ItemsSource="{Binding RiteSlots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RiteSlotViewModel">
                                    <Grid ColumnDefinitions="64,*" Margin="0,3">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource ParchmentDim}" />
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding Options}"
                                                  SelectedItem="{Binding Rite}" HorizontalAlignment="Stretch" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Spacing="6" Margin="0,0,0,14">
                        <CheckBox Content="Poison" IsChecked="{Binding PoisonEnabled}" IsEnabled="{Binding PoisonPossible}" />
                        <CheckBox Content="Open 4th layer" IsChecked="{Binding FourthLayerOpen}" IsEnabled="{Binding FourthLayerPossible}" />
                    </StackPanel>

                    <TextBlock Grid.Row="4" Text="Live bytes (125)" FontSize="13"
                               Foreground="{DynamicResource ParchmentDim}" Margin="0,0,0,4" />
                    <Border Grid.Row="5" Background="{DynamicResource BgBase}" BorderBrush="{DynamicResource Edge}" BorderThickness="1">
                        <TextBox Text="{Binding SlotHexDump, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Cascadia Mono,Consolas,Menlo,monospace" FontSize="11"
                                 Foreground="{DynamicResource Parchment}" Background="Transparent" BorderThickness="0"
                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                 VerticalAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Blood}" BorderThickness="0,2,0,0" Padding="24,10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource Parchment}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Dungeons.Count, StringFormat='{}{0} shown'}"
                           Foreground="{DynamicResource ParchmentDim}" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
