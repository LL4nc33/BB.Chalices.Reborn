<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BB.Chalices.ViewModels"
        x:Class="BB.Chalices.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1280" Height="820" MinWidth="1160" MinHeight="740"
        RequestedThemeVariant="Dark"
        FontFamily="{DynamicResource GothicFont}"
        Title="BB Chalices">

    <Window.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#100F14" />
            <GradientStop Offset="1" Color="#070709" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Blood}" BorderThickness="0,0,0,2" Padding="24,16">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Chalice Dungeon Editor" FontSize="27" FontWeight="Bold"
                               Foreground="{DynamicResource Parchment}" />
                    <TextBlock FontSize="14" Foreground="{DynamicResource BloodBright}"
                               Text="{Binding CharacterName, StringFormat='Hunter: {0}'}"
                               IsVisible="{Binding HasLoadedSave}" />
                    <TextBlock FontSize="14" Foreground="{DynamicResource ParchmentDim}"
                               Text="No save loaded" IsVisible="{Binding !HasLoadedSave}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="Open Save…" Click="OnOpenSaveClick"
                            ToolTip.Tip="Open a Bloodborne save file (userdata…) to edit" />
                    <Button Content="Backups" Click="OnBackupsClick"
                            ToolTip.Tip="Browse, restore or delete your save backups" />
                    <Button Content="Settings" Click="OnSettingsClick"
                            ToolTip.Tip="Set the shadPS4 folder, backup folder and auto-backup" />
                    <Button Classes="primary" Content="Save" Command="{Binding SaveCommand}"
                            IsEnabled="{Binding HasLoadedSave}" HotKey="Ctrl+S"
                            ToolTip.Tip="Write your changes back to the save (Ctrl+S). A backup is made first." />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Body: catalogue + editor controls -->
        <Grid Grid.Row="1" Margin="16,16,16,8" ColumnDefinitions="*,16,380">

            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="{DynamicResource BgPanel}"
                        BorderBrush="{DynamicResource Edge}" BorderThickness="1" Padding="14,12" Margin="0,0,0,14">
                    <Grid ColumnDefinitions="Auto,Auto,*">
                        <TextBlock Grid.Column="0" Classes="section" Text="SHADPS4 SAVES"
                                   VerticalAlignment="Center" Margin="0,0,14,0" />
                        <Button Grid.Column="1" Content="Detect" Command="{Binding DetectSavesCommand}" Margin="0,0,10,0"
                                ToolTip.Tip="Find your shadPS4 characters automatically" />
                        <ComboBox Grid.Column="2" ItemsSource="{Binding DetectedSaves}" SelectedItem="{Binding SelectedDetectedSave}"
                                  HorizontalAlignment="Stretch" PlaceholderText="detected characters…"
                                  ToolTip.Tip="Pick a detected character to load it">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DetectedSaveViewModel">
                                    <TextBlock Text="{Binding FileName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource BgPanel}"
                        BorderBrush="{DynamicResource Edge}" BorderThickness="1" Padding="16">
                    <Grid RowDefinitions="Auto,Auto,*,Auto">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                            <TextBlock Grid.Column="0" Classes="section" Text="CATALOGUE" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Update online" Command="{Binding UpdateDungeonsCommand}"
                                    Padding="10,4" FontSize="12"
                                    ToolTip.Tip="Fetch the latest dungeon list from Noxde's gist" />
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="*,170" Margin="0,0,0,12">
                            <TextBox Grid.Column="0" Text="{Binding SearchText}"
                                     PlaceholderText="Search glyphs or descriptions…" Margin="0,0,8,0"
                                     ToolTip.Tip="Filter the catalogue by glyph or description" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory}" HorizontalAlignment="Stretch"
                                      ToolTip.Tip="Show only one category of dungeon" />
                        </Grid>
                        <ListBox Grid.Row="2" ItemsSource="{Binding Dungeons}" SelectedItem="{Binding SelectedDungeon}"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DungeonViewModel">
                                    <StackPanel Spacing="2" ToolTip.Tip="{Binding DisplayName}">
                                        <TextBlock Text="{Binding Glyph}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Parchment}" />
                                        <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{DynamicResource BloodBright}" />
                                        <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource ParchmentDim}"
                                                   IsVisible="{Binding Description, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,12,0,0">
                            <Button Grid.Column="0" Classes="primary" Content="Place in selected slot"
                                    Command="{Binding ApplyDungeonCommand}" HorizontalAlignment="Stretch"
                                    ToolTip.Tip="Write the selected dungeon into the chosen altar slot" />
                            <Button Grid.Column="1" Content="Build new…" Click="OnBuilderClick"
                                    IsEnabled="{Binding HasLoadedSave}"
                                    ToolTip.Tip="Generate a fresh dungeon by area, variant and layout" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2" Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource Edge}" BorderThickness="1" Padding="18">
                <StackPanel Spacing="0">
                    <TextBlock Classes="section" Text="SLOT" Margin="0,0,0,6" />
                    <ComboBox ItemsSource="{Binding Slots}" SelectedItem="{Binding SelectedSlot}" HorizontalAlignment="Stretch"
                              ToolTip.Tip="Choose which of the six altar slots to view and edit">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SlotViewModel">
                                <TextBlock Text="{Binding Display}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{Binding SelectedSlotType}" FontSize="21" FontWeight="Bold"
                               Foreground="{DynamicResource BloodBright}" Margin="0,8,0,18" />

                    <TextBlock Classes="section" Text="RITES" Margin="0,0,0,6" />
                    <ItemsControl ItemsSource="{Binding RiteSlots}" Margin="0,0,0,16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RiteSlotViewModel">
                                <Grid ColumnDefinitions="64,*" Margin="0,3"
                                      ToolTip.Tip="Set a rite (Fetid, Rotted, Cursed or Sinister) for this slot, or None to remove it">
                                    <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource ParchmentDim}" />
                                    <ComboBox Grid.Column="1" ItemsSource="{Binding Options}"
                                              SelectedItem="{Binding Rite}" HorizontalAlignment="Stretch" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Classes="section" Text="MODIFIERS" Margin="0,0,0,6"
                               ToolTip.Tip="Only certain dungeon types support poison or a 4th layer; the others stay greyed out." />
                    <StackPanel Spacing="8">
                        <CheckBox Content="Poison" IsChecked="{Binding PoisonEnabled}" IsEnabled="{Binding PoisonPossible}"
                                  ToolTip.Tip="Toggle the poison mist (only some dungeon types can be poisoned)" />
                        <CheckBox Content="Open 4th layer" IsChecked="{Binding FourthLayerOpen}" IsEnabled="{Binding FourthLayerPossible}"
                                  ToolTip.Tip="Open or close the optional 4th layer (only some dungeons have one)" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Advanced…" Click="OnAdvancedClick"
                                HorizontalAlignment="Stretch" IsEnabled="{Binding HasLoadedSave}"
                                ToolTip.Tip="Edit each headstone field directly as raw hex" />
                        <Button Grid.Column="1" Content="Clear slot" Command="{Binding ClearSlotCommand}"
                                HorizontalAlignment="Stretch"
                                ToolTip.Tip="Empty this altar slot" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Live bytes (HxD style, full width) -->
        <Border Grid.Row="2" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Edge}" BorderThickness="1" Margin="16,0,16,10" Padding="16,12"
                ToolTip.Tip="The selected slot's 125 bytes in the save file. '..' marks bytes that belong to other slots.">
            <StackPanel Spacing="8">
                <TextBlock Classes="section" Text="LIVE BYTES" />
                <Border Background="{DynamicResource BgBase}" BorderBrush="{DynamicResource Edge}" BorderThickness="1" Padding="14,10">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <SelectableTextBlock Text="{Binding SlotHexDump}"
                                             FontFamily="Cascadia Mono,Consolas,Menlo,monospace" FontSize="13"
                                             Foreground="{DynamicResource Parchment}" />
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Blood}" BorderThickness="0,2,0,0" Padding="24,10">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource Parchment}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Dungeons.Count, StringFormat='{}{0} shown'}"
                           Foreground="{DynamicResource ParchmentDim}" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
