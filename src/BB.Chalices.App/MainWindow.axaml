<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BB.Chalices.ViewModels"
        x:Class="BB.Chalices.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1366" Height="850" MinWidth="1240" MinHeight="780"
        RequestedThemeVariant="Dark"
        FontFamily="{DynamicResource GothicFont}"
        Icon="/Assets/favicon.png"
        Title="BB Chalices">

    <Window.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
            <GradientStop Offset="0" Color="#100F14" />
            <GradientStop Offset="1" Color="#070709" />
        </LinearGradientBrush>
    </Window.Background>

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0" ColumnDefinitions="220,*">

            <!-- LEFT: navigation + actions -->
            <Border Grid.Column="0" Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource Edge}" BorderThickness="0,0,1,0">
                <DockPanel Margin="16,18">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="9" Margin="2,0,0,20">
                        <Image Source="/Assets/favicon.png" Width="26" Height="26" VerticalAlignment="Center" />
                        <TextBlock Text="BB Chalices" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource Parchment}" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" Margin="2,16,0,0">
                        <TextBlock Text="{Binding CharacterName, StringFormat='Hunter: {0}'}" FontSize="13"
                                   Foreground="{DynamicResource BloodBright}" TextWrapping="Wrap"
                                   IsVisible="{Binding HasLoadedSave}" />
                        <TextBlock Text="No save loaded" FontSize="13" Foreground="{DynamicResource ParchmentDim}"
                                   IsVisible="{Binding !HasLoadedSave}" />
                    </StackPanel>

                    <StackPanel Spacing="7">
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="{DynamicResource Blood}"
                                    IsVisible="{Binding IsCatalogueView}" />
                            <Button Classes="nav" Content="Catalogue" Click="OnShowCatalogue"
                                    ToolTip.Tip="Browse and place dungeons" />
                        </Grid>
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="{DynamicResource Blood}"
                                    IsVisible="{Binding IsSettingsView}" />
                            <Button Classes="nav" Content="Settings" Click="OnShowSettings"
                                    ToolTip.Tip="shadPS4 folder, backups, credits and sources" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Edge}" Margin="0,10" />

                        <Button Classes="nav" Content="Open save" Click="OnOpenSaveClick" HotKey="Ctrl+O"
                                ToolTip.Tip="Open a Bloodborne save file (Ctrl+O)" />
                        <Button Classes="nav" Content="Detect saves" Command="{Binding DetectSavesCommand}"
                                ToolTip.Tip="Find your shadPS4 characters automatically" />
                        <ComboBox ItemsSource="{Binding DetectedSaves}" SelectedItem="{Binding SelectedDetectedSave}"
                                  HorizontalAlignment="Stretch" PlaceholderText="detected characters"
                                  ToolTip.Tip="Pick a detected character to load it">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DetectedSaveViewModel">
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="{Binding FileName}" />
                                        <TextBlock Text="{Binding Location}" FontSize="11"
                                                   Foreground="{DynamicResource ParchmentDim}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Border Height="1" Background="{DynamicResource Edge}" Margin="0,10" />

                        <Button Classes="nav primary" Content="Save" Command="{Binding SaveCommand}"
                                IsEnabled="{Binding HasLoadedSave}" HotKey="Ctrl+S"
                                ToolTip.Tip="Write your changes to the save (Ctrl+S). A backup is made first." />
                        <Button Classes="nav" Content="Undo" Command="{Binding UndoSlotCommand}" IsEnabled="{Binding CanUndo}"
                                ToolTip.Tip="Revert the last slot change before saving" />
                        <Button Classes="nav" Content="Backups" Click="OnBackupsClick"
                                ToolTip.Tip="Browse, restore or delete backups" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- CENTRE/RIGHT: the content host (catalogue workspace or settings page) -->
            <Panel Grid.Column="1">

                <!-- Catalogue workspace -->
                <Grid ColumnDefinitions="*,580" IsVisible="{Binding IsCatalogueView}">

                    <Grid Grid.Column="0" Margin="22,18" RowDefinitions="Auto,Auto,*,Auto,Auto">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
                            <TextBlock Grid.Column="0" Text="Catalogue" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource Parchment}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                                <Button Classes="toggle" Classes.active="{Binding ShowNox}" Content="Noxde" Click="OnShowNox"
                                        ToolTip.Tip="Noxde's curated farming, equipment and gem dungeons" />
                                <Button Classes="toggle" Classes.active="{Binding ShowAll}" Content="All" Click="OnShowAll"
                                        ToolTip.Tip="The full Tomb Prospectors set by area" />
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="*,200" Margin="0,0,0,12">
                            <TextBox Grid.Column="0" Text="{Binding SearchText}" FontSize="15"
                                     PlaceholderText="Search glyph, boss or loot" Margin="0,0,10,0"
                                     ToolTip.Tip="Filter by glyph, description, boss or note" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                                      HorizontalAlignment="Stretch" FontSize="15" ToolTip.Tip="Show only one category" />
                        </Grid>
                        <ListBox Grid.Row="2" ItemsSource="{Binding Dungeons}" SelectedItem="{Binding SelectedDungeon}"
                                 Background="Transparent" BorderThickness="0" DoubleTapped="OnCatalogueDoubleTapped">
                            <ListBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding ApplyDungeonCommand}" />
                            </ListBox.KeyBindings>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DungeonViewModel">
                                    <StackPanel Spacing="3" ToolTip.Tip="{Binding DisplayName}">
                                        <TextBlock Text="{Binding Glyph}" FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Parchment}" />
                                        <TextBlock Text="{Binding Category}" FontSize="13" Foreground="{DynamicResource BloodBright}" />
                                        <TextBlock Text="{Binding Description}" FontSize="14" TextWrapping="Wrap"
                                                   MaxLines="2" TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource ParchmentDim}"
                                                   IsVisible="{Binding Description, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="3" Margin="0,12,0,0" Padding="0,12,0,0"
                                BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0"
                                IsVisible="{Binding SelectedDungeon, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <StackPanel DataContext="{Binding SelectedDungeon}" x:DataType="vm:DungeonViewModel" Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding Glyph}" FontSize="17" FontWeight="Bold"
                                               Foreground="{DynamicResource Parchment}" />
                                    <TextBlock Text="{Binding Type}" FontSize="14" VerticalAlignment="Center"
                                               Foreground="{DynamicResource BloodBright}" />
                                </StackPanel>
                                <TextBlock Text="{Binding JoinRequirement, StringFormat='Requires: {0} chalice'}"
                                           FontSize="13" Foreground="{DynamicResource ParchmentDim}" />
                                <WrapPanel>
                                    <TextBlock Text="{Binding Rites, StringFormat='Rites: {0}'}" FontSize="13"
                                               Foreground="{DynamicResource Parchment}" Margin="0,0,16,0" />
                                    <TextBlock Text="Poison" FontSize="13" Foreground="{DynamicResource BloodBright}"
                                               Margin="0,0,16,0" IsVisible="{Binding IsPoisoned}" />
                                    <TextBlock Text="4th layer" FontSize="13" Foreground="{DynamicResource BloodBright}"
                                               IsVisible="{Binding HasFourthLayer}" />
                                </WrapPanel>
                                <ScrollViewer MaxHeight="104" VerticalScrollBarVisibility="Auto"
                                              IsVisible="{Binding Description, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Text="{Binding Description}" FontSize="13" TextWrapping="Wrap"
                                               Foreground="{DynamicResource ParchmentDim}" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,14,0,0">
                            <Button Grid.Column="0" Classes="primary" Content="Place in selected slot" FontSize="14"
                                    Command="{Binding ApplyDungeonCommand}" HorizontalAlignment="Stretch"
                                    IsEnabled="{Binding HasLoadedSave}"
                                    ToolTip.Tip="Write the selected dungeon into the chosen slot" />
                            <Button Grid.Column="1" Content="Build new" Click="OnBuilderClick" FontSize="14"
                                    IsEnabled="{Binding HasLoadedSave}"
                                    ToolTip.Tip="Generate a dungeon by area, variant and layout" />
                        </Grid>
                    </Grid>

                    <Border Grid.Column="1" Background="{DynamicResource BgPanel}"
                            BorderBrush="{DynamicResource Edge}" BorderThickness="1,0,0,0">
                        <Grid Margin="20,18" RowDefinitions="Auto,*,Auto" IsEnabled="{Binding HasLoadedSave}">
                            <StackPanel Grid.Row="0" Spacing="6">
                                <TextBlock Classes="section" Text="ALTAR SLOT" />
                                <ListBox Classes="slots" ItemsSource="{Binding Slots}" SelectedItem="{Binding SelectedSlot}"
                                         Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch"
                                         ToolTip.Tip="Pick one of the six altar slots (a dot marks an occupied slot)">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="6" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SlotViewModel">
                                            <StackPanel Spacing="3">
                                                <TextBlock Text="{Binding Number}" FontSize="18" FontWeight="Bold"
                                                           HorizontalAlignment="Center" Foreground="{DynamicResource Parchment}" />
                                                <Ellipse Width="6" Height="6" HorizontalAlignment="Center"
                                                         Fill="{DynamicResource BloodBright}" IsVisible="{Binding Occupied}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Text="{Binding SelectedSlotType}" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource BloodBright}" Margin="0,8,0,0"
                                           IsVisible="{Binding SelectedSlotType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <TextBlock Text="{Binding SelectedSlotJoin, StringFormat='Requires: {0} chalice'}"
                                           FontSize="13" Foreground="{DynamicResource ParchmentDim}"
                                           IsVisible="{Binding SelectedSlotJoin, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>

                            <TabControl Grid.Row="1" Margin="0,14,0,0">
                                <TabItem Header="Edit">
                                    <StackPanel Spacing="0" Margin="0,12,0,0">
                                        <TextBlock Classes="section" Text="RITES" Margin="0,0,0,8" />
                                        <ItemsControl ItemsSource="{Binding RiteSlots}" Margin="0,0,0,18">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:RiteSlotViewModel">
                                                    <Grid ColumnDefinitions="80,*" Margin="0,4"
                                                          ToolTip.Tip="Set a rite (Fetid, Rotted, Cursed or Sinister), or None to remove it">
                                                        <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                                                   FontSize="14" Foreground="{DynamicResource ParchmentDim}" />
                                                        <ComboBox Grid.Column="1" ItemsSource="{Binding Options}"
                                                                  SelectedItem="{Binding Rite}" HorizontalAlignment="Stretch" FontSize="14" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Classes="section" Text="MODIFIERS" Margin="0,0,0,8"
                                                   ToolTip.Tip="Only certain dungeon types support poison or a 4th layer." />
                                        <StackPanel Spacing="10">
                                            <CheckBox Content="Poison" FontSize="14" IsChecked="{Binding PoisonEnabled}"
                                                      IsEnabled="{Binding PoisonPossible}"
                                                      ToolTip.Tip="Toggle the poison mist (only some dungeon types)" />
                                            <CheckBox Content="Open 4th layer" FontSize="14" IsChecked="{Binding FourthLayerOpen}"
                                                      IsEnabled="{Binding FourthLayerPossible}"
                                                      ToolTip.Tip="Open or close the optional 4th layer (only some dungeons)" />
                                        </StackPanel>

                                        <Button Content="Clear slot" Command="{Binding ClearSlotCommand}"
                                                HorizontalAlignment="Stretch" Margin="0,22,0,0" FontSize="14"
                                                ToolTip.Tip="Empty this altar slot" />
                                    </StackPanel>
                                </TabItem>
                                <TabItem Header="Fields">
                                    <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto"
                                                  ToolTip.Tip="Edit each headstone field as raw hex. A change applies once it is the right length.">
                                        <ItemsControl ItemsSource="{Binding Fields}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:HeadstoneFieldViewModel">
                                                    <Grid ColumnDefinitions="140,*" Margin="0,4" ToolTip.Tip="{Binding OffsetLabel}">
                                                        <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                                                   FontSize="13" Foreground="{DynamicResource Parchment}" />
                                                        <TextBox Grid.Column="1" Text="{Binding Hex}" FontSize="13"
                                                                 FontFamily="Cascadia Mono,Consolas,Menlo,monospace" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>

                            <StackPanel Grid.Row="2" Spacing="8" Margin="0,16,0,0">
                                <TextBlock Classes="section" Text="LIVE BYTES" />
                                <Border Background="{DynamicResource BgBase}" BorderBrush="{DynamicResource Edge}"
                                        BorderThickness="1" Padding="12,10">
                                    <Panel>
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="240">
                                            <SelectableTextBlock Text="{Binding SlotHexDump}"
                                                                 FontFamily="Cascadia Mono,Consolas,Menlo,monospace" FontSize="11"
                                                                 Foreground="{DynamicResource Parchment}"
                                                                 IsVisible="{Binding SlotHexDump, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </ScrollViewer>
                                        <TextBlock Text="Open a save to inspect the slot's 125 bytes" FontSize="13"
                                                   Foreground="{DynamicResource ParchmentDim}" VerticalAlignment="Center"
                                                   IsVisible="{Binding SlotHexDump, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                    </Panel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Settings page -->
                <ScrollViewer IsVisible="{Binding IsSettingsView}">
                    <StackPanel Margin="28,22" Spacing="18" MaxWidth="680" HorizontalAlignment="Left">
                        <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource Parchment}" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="shadPS4 folder" FontSize="13" Foreground="{DynamicResource ParchmentDim}" />
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" Text="{Binding ShadPs4Path}" FontSize="14" Margin="0,0,8,0"
                                         PlaceholderText="leave empty to auto-detect"
                                         ToolTip.Tip="Your shadPS4 folder. Leave empty to auto-detect it." />
                                <Button Grid.Column="1" Content="Browse" Click="OnBrowseShad" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Backup folder" FontSize="13" Foreground="{DynamicResource ParchmentDim}" />
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBox Grid.Column="0" Text="{Binding BackupPath}" FontSize="14" Margin="0,0,8,0"
                                         ToolTip.Tip="Folder where your backups are kept" />
                                <Button Grid.Column="1" Content="Browse" Click="OnBrowseBackup" Margin="0,0,8,0" />
                                <Button Grid.Column="2" Content="Open" Click="OnOpenBackupFolder" ToolTip.Tip="Open the backup folder" />
                            </Grid>
                        </StackPanel>

                        <CheckBox Content="Back up automatically before every save" FontSize="14"
                                  IsChecked="{Binding AutoBackup}" Foreground="{DynamicResource Parchment}"
                                  ToolTip.Tip="Keep a timestamped backup every time you save" />

                        <Border BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Credits and sources" FontSize="13" Foreground="{DynamicResource ParchmentDim}" />
                                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource ParchmentDim}"
                                           Text="The chalice byte format builds on the Tomb Prospectors community (DrAnger, Trin, Kazin). Dig into the research yourself:" />
                                <WrapPanel>
                                    <Button Content="Hex Research Central" Tag="https://www.bloodborne-wiki.com/2017/12/data-mining.html"
                                            Click="OnOpenLink" Margin="0,0,8,8" />
                                    <Button Content="Bloodborne Wiki" Tag="https://www.bloodborne-wiki.com/"
                                            Click="OnOpenLink" Margin="0,0,8,8" />
                                    <Button Content="Noxde's dungeon list" Tag="https://www.nexusmods.com/bloodborne/mods/121"
                                            Click="OnOpenLink" Margin="0,0,8,8" />
                                    <Button Content="shadPS4" Tag="https://shadps4.net" Click="OnOpenLink" Margin="0,0,8,8" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Cancel" Click="OnShowCatalogue" FontSize="14" />
                            <Button Classes="primary" Content="Save settings" Click="OnSaveSettings" FontSize="14" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Panel>
        </Grid>

        <!-- status bar -->
        <Border Grid.Row="1" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Blood}" BorderThickness="0,1,0,0" Padding="22,9">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="13"
                           Foreground="{DynamicResource Parchment}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding Dungeons.Count, StringFormat='{}{0} shown'}" FontSize="13"
                           Foreground="{DynamicResource ParchmentDim}" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
