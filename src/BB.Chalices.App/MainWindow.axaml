<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BB.Chalices.ViewModels"
        xmlns:services="using:BB.Chalices.Services"
        x:Class="BB.Chalices.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1366" Height="850" MinWidth="1240" MinHeight="780"
        RequestedThemeVariant="Dark"
        FontFamily="{DynamicResource GothicFont}"
        Icon="/Assets/favicon.png"
        Background="{DynamicResource WindowBg}"
        Title="BB Chalices">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0" ColumnDefinitions="220,*">

            <!-- LEFT: navigation + actions -->
            <Border Grid.Column="0" Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource Edge}" BorderThickness="0,0,1,0">
                <DockPanel Margin="20">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,20">
                        <Image Source="/Assets/favicon.png" Width="26" Height="26" VerticalAlignment="Center" />
                        <TextBlock Classes="heading" Text="BB Chalices" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- the save lives in its own block at the bottom, with one big Save button -->
                    <StackPanel DockPanel.Dock="Bottom" Spacing="8">
                        <Border Height="1" Background="{DynamicResource Edge}" />
                        <TextBlock Classes="section" Text="CURRENT SAVE" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Content="Open" Click="OnOpenSaveClick" HotKey="Ctrl+O"
                                    HorizontalAlignment="Stretch" ToolTip.Tip="Open a Bloodborne save file (Ctrl+O)" />
                            <Button Grid.Column="1" Content="Detect" Command="{Binding DetectSavesCommand}"
                                    HorizontalAlignment="Stretch" ToolTip.Tip="Find your shadPS4 characters automatically" />
                        </Grid>
                        <ComboBox ItemsSource="{Binding DetectedSaves}" SelectedItem="{Binding SelectedDetectedSave}"
                                  HorizontalAlignment="Stretch" PlaceholderText="detected characters"
                                  ToolTip.Tip="Pick a detected character to load it">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DetectedSaveViewModel">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Title}" />
                                        <TextBlock Classes="caption" Text="{Binding Subtitle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" IsVisible="{Binding HasLoadedSave}"
                              ToolTip.Tip="The hunter's name. Edit it, click Rename, then Save changes to write it.">
                            <TextBox Grid.Column="0" Text="{Binding EditableName}" MaxLength="16" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Rename" Command="{Binding RenameCommand}" />
                        </Grid>
                        <TextBlock Classes="caption" Text="No save loaded"
                                   IsVisible="{Binding !HasLoadedSave}" />
                    </StackPanel>

                    <!-- navigation between the centre views -->
                    <StackPanel VerticalAlignment="Top" Spacing="8">
                        <TextBlock Classes="section" Text="VIEWS" />
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="{DynamicResource Blood}"
                                    IsVisible="{Binding IsCatalogueView}" />
                            <Button Classes="nav" Content="Catalogue" Click="OnShowCatalogue"
                                    ToolTip.Tip="Browse and place dungeons" />
                        </Grid>
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="{DynamicResource Blood}"
                                    IsVisible="{Binding IsSettingsView}" />
                            <Button Classes="nav" Content="Settings" Click="OnShowSettings"
                                    ToolTip.Tip="shadPS4 folder, auto-backup, credits and sources" />
                        </Grid>
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="{DynamicResource Blood}"
                                    IsVisible="{Binding IsBackupsView}" />
                            <Button Classes="nav" Content="Backups" Click="OnShowBackups"
                                    ToolTip.Tip="Browse, restore or delete backups" />
                        </Grid>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- CENTRE/RIGHT: the content host (catalogue workspace or settings page) -->
            <Panel Grid.Column="1">

                <!-- Catalogue workspace -->
                <Grid ColumnDefinitions="*,580" IsVisible="{Binding IsCatalogueView}">

                    <Grid Grid.Column="0" Margin="20" RowDefinitions="Auto,Auto,*,Auto,Auto">
                        <StackPanel Grid.Row="0">
                            <Border Classes="accent" IsVisible="{Binding !HasLoadedSave}" Padding="16" Margin="0,0,0,16">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="title" Text="Welcome to BB Chalices" />
                                    <TextBlock Classes="body" TextWrapping="Wrap"
                                               Text="Swap the chalice dungeons in your Bloodborne save. Drop any of 2300+ ready-made dungeons onto your altar, turn rites and effects on or off, or build your own. Every change is backed up before it is written." />
                                    <TextBlock Classes="section" Text="HOW IT WORKS" />
                                    <TextBlock Classes="body" TextWrapping="Wrap"
                                               Text="1.  Load your save: Open save or Detect saves, bottom left." />
                                    <TextBlock Classes="body" TextWrapping="Wrap"
                                               Text="2.  Pick a dungeon below. Search by boss, loot or glyph." />
                                    <TextBlock Classes="body" TextWrapping="Wrap"
                                               Text="3.  Choose a slot on the right, then Place in selected slot." />
                                    <TextBlock Classes="body" TextWrapping="Wrap"
                                               Text="4.  Tweak rites if you like, then Save changes." />
                                </StackPanel>
                            </Border>
                            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
                                <TextBlock Grid.Column="0" Classes="title" Text="Catalogue" VerticalAlignment="Center" />
                                <UniformGrid Grid.Column="2" Columns="2" VerticalAlignment="Center">
                                    <Button Classes="toggle" Classes.active="{Binding ShowNox}" Content="Noxde" Click="OnShowNox"
                                            HorizontalAlignment="Stretch"
                                            ToolTip.Tip="Noxde's curated farming, equipment and gem dungeons" />
                                    <Button Classes="toggle" Classes.active="{Binding ShowAll}" Content="All" Click="OnShowAll"
                                            HorizontalAlignment="Stretch"
                                            ToolTip.Tip="The full Tomb Prospectors set by area" />
                                </UniformGrid>
                            </Grid>
                        </StackPanel>
                        <Grid Grid.Row="1" ColumnDefinitions="*,200" Margin="0,0,0,12">
                            <TextBox Grid.Column="0" Text="{Binding SearchText}"
                                     PlaceholderText="Search glyph, boss or loot" Margin="0,0,8,0"
                                     ToolTip.Tip="Filter by glyph, description, boss or note" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                                      HorizontalAlignment="Stretch" ToolTip.Tip="Show only one category" />
                        </Grid>
                        <ListBox Grid.Row="2" Classes="plain" ItemsSource="{Binding Dungeons}" SelectedItem="{Binding SelectedDungeon}"
                                 DoubleTapped="OnCatalogueDoubleTapped">
                            <ListBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding ApplyDungeonCommand}" />
                            </ListBox.KeyBindings>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DungeonViewModel">
                                    <StackPanel Spacing="4" ToolTip.Tip="{Binding DisplayName}">
                                        <TextBlock Classes="heading" Text="{Binding Glyph}" />
                                        <TextBlock Classes="caption accent" Text="{Binding Category}" />
                                        <TextBlock Classes="body" Text="{Binding Description}" TextWrapping="Wrap"
                                                   MaxLines="2" TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource ParchmentDim}"
                                                   IsVisible="{Binding Description, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="3" Margin="0,16,0,0" Padding="0,12,0,0"
                                BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0"
                                IsVisible="{Binding SelectedDungeon, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <StackPanel DataContext="{Binding SelectedDungeon}" x:DataType="vm:DungeonViewModel" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Classes="heading" Text="{Binding Glyph}" />
                                    <TextBlock Classes="body accent" Text="{Binding Type}" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Classes="body accent" Text="{Binding UniqueItem, StringFormat='Coffin: {0}'}"
                                           FontWeight="SemiBold" TextWrapping="Wrap"
                                           IsVisible="{Binding UniqueItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <TextBlock Classes="caption" Text="{Binding JoinRequirement, StringFormat='Requires: {0} chalice'}" />
                                <WrapPanel>
                                    <TextBlock Classes="caption" Text="{Binding Rites, StringFormat='Rites: {0}'}" Margin="0,0,16,0" />
                                    <TextBlock Classes="caption accent" Text="Poison"
                                               Margin="0,0,16,0" IsVisible="{Binding IsPoisoned}" />
                                    <TextBlock Classes="caption accent" Text="4th layer"
                                               IsVisible="{Binding HasFourthLayer}" />
                                </WrapPanel>
                                <ScrollViewer MaxHeight="104" VerticalScrollBarVisibility="Auto"
                                              IsVisible="{Binding Description, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Classes="caption" Text="{Binding Description}" TextWrapping="Wrap" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="4" ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,16,0,0">
                            <Button Grid.Column="0" Content="Build new" Click="OnBuilderClick"
                                    IsEnabled="{Binding HasLoadedSave}"
                                    ToolTip.Tip="Generate a dungeon by area, variant and layout" />
                            <Button Grid.Column="1" Classes="primary" Content="Place in selected slot"
                                    Command="{Binding ApplyDungeonCommand}" HorizontalAlignment="Stretch"
                                    IsEnabled="{Binding HasLoadedSave}"
                                    ToolTip.Tip="Write the selected dungeon into the chosen slot" />
                        </Grid>
                    </Grid>

                    <Border Grid.Column="1" Background="{DynamicResource BgPanel}"
                            BorderBrush="{DynamicResource Edge}" BorderThickness="1,0,0,0">
                        <Grid Margin="20" RowDefinitions="Auto,*,Auto,Auto" IsEnabled="{Binding HasLoadedSave}">
                            <StackPanel Grid.Row="0" Spacing="8">
                                <Grid ColumnDefinitions="Auto,*">
                                <TextBlock Grid.Column="0" Classes="section" Text="ALTAR SLOT"
                                           VerticalAlignment="Center" Margin="0,0,12,0" />
                                <ListBox Grid.Column="1" Classes="slots plain" ItemsSource="{Binding Slots}" SelectedItem="{Binding SelectedSlot}"
                                         HorizontalAlignment="Stretch"
                                         ToolTip.Tip="Pick one of the six altar slots (a dot marks an occupied slot)">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="6" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SlotViewModel">
                                            <Panel>
                                                <TextBlock Classes="heading" Text="{Binding Number}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="5" Height="5" Margin="0,0,3,0"
                                                         HorizontalAlignment="Right" VerticalAlignment="Top"
                                                         Fill="{DynamicResource BloodBright}" IsVisible="{Binding Occupied}" />
                                            </Panel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                </Grid>
                                <TextBlock Classes="heading accent" Text="{Binding SelectedSlotType}" Margin="0,8,0,0"
                                           IsVisible="{Binding SelectedSlotType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <TextBlock Classes="caption" Text="{Binding SelectedSlotJoin, StringFormat='Requires: {0} chalice'}"
                                           IsVisible="{Binding SelectedSlotJoin, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>

                            <TabControl Grid.Row="1" Margin="0,16,0,0">
                                <TabItem Header="Edit">
                                    <StackPanel Spacing="0" Margin="0,12,0,0">
                                        <TextBlock Classes="section" Text="RITES" />
                                        <ItemsControl ItemsSource="{Binding RiteSlots}" Margin="0,0,0,16">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:RiteSlotViewModel">
                                                    <Grid ColumnDefinitions="80,*" Margin="0,4"
                                                          ToolTip.Tip="Set a rite (Fetid, Rotted, Cursed or Sinister), or None to remove it">
                                                        <TextBlock Grid.Column="0" Classes="caption" Text="{Binding Label}" VerticalAlignment="Center" />
                                                        <ComboBox Grid.Column="1" ItemsSource="{Binding Options}"
                                                                  SelectedItem="{Binding Rite}" HorizontalAlignment="Stretch" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Classes="section" Text="MODIFIERS"
                                                   ToolTip.Tip="Only certain dungeon types support poison or a 4th layer." />
                                        <StackPanel Spacing="8">
                                            <CheckBox Content="Poison" IsChecked="{Binding PoisonEnabled}"
                                                      IsEnabled="{Binding PoisonPossible}"
                                                      ToolTip.Tip="Toggle the poison mist (only some dungeon types)" />
                                            <CheckBox Content="Open 4th layer" IsChecked="{Binding FourthLayerOpen}"
                                                      IsEnabled="{Binding FourthLayerPossible}"
                                                      ToolTip.Tip="Open or close the optional 4th layer (only some dungeons)" />
                                        </StackPanel>

                                        <Button Classes="danger" Content="Clear slot" Command="{Binding ClearSlotCommand}"
                                                HorizontalAlignment="Stretch" Margin="0,16,0,0"
                                                ToolTip.Tip="Empty this altar slot" />
                                    </StackPanel>
                                </TabItem>
                                <TabItem Header="Fields">
                                    <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto"
                                                  ToolTip.Tip="Edit each headstone field as raw hex. A change applies once it is the right length.">
                                        <ItemsControl ItemsSource="{Binding Fields}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:HeadstoneFieldViewModel">
                                                    <Grid ColumnDefinitions="140,*" Margin="0,4" ToolTip.Tip="{Binding OffsetLabel}">
                                                        <TextBlock Grid.Column="0" Classes="caption" Text="{Binding Label}" VerticalAlignment="Center" />
                                                        <TextBox Grid.Column="1" Text="{Binding Hex}" FontSize="13"
                                                                 FontFamily="Cascadia Mono,Consolas,Menlo,monospace" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>

                            <StackPanel Grid.Row="2" Spacing="8" Margin="0,16,0,0">
                                <TextBlock Classes="section" Text="LIVE BYTES" />
                                <Border Classes="hexPanel">
                                    <Panel>
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="240">
                                            <SelectableTextBlock Text="{Binding SlotHexDump}"
                                                                 FontFamily="Cascadia Mono,Consolas,Menlo,monospace" FontSize="11"
                                                                 Foreground="{DynamicResource Parchment}"
                                                                 IsVisible="{Binding SlotHexDump, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </ScrollViewer>
                                        <TextBlock Classes="caption" Text="Open a save to inspect the slot's 125 bytes" VerticalAlignment="Center"
                                                   IsVisible="{Binding SlotHexDump, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                    </Panel>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,16,0,0">
                                <Button Grid.Column="0" Content="Undo" Command="{Binding UndoSlotCommand}" IsEnabled="{Binding CanUndo}"
                                        ToolTip.Tip="Revert the last slot change before saving" />
                                <Button Grid.Column="1" Classes="primary" Content="Save changes" Command="{Binding SaveCommand}"
                                        IsEnabled="{Binding HasLoadedSave}" HotKey="Ctrl+S" HorizontalAlignment="Stretch"
                                        ToolTip.Tip="Write all your changes to the save file (Ctrl+S). A backup is made first." />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Settings page -->
                <ScrollViewer IsVisible="{Binding IsSettingsView}">
                    <StackPanel Margin="20" Spacing="20" MaxWidth="680" HorizontalAlignment="Left">
                        <TextBlock Classes="title" Text="Settings" />

                        <StackPanel Spacing="8">
                            <TextBlock Classes="caption" Text="shadPS4 folder" />
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" Text="{Binding ShadPs4Path}" Margin="0,0,8,0"
                                         PlaceholderText="leave empty to auto-detect"
                                         ToolTip.Tip="Your shadPS4 folder. Leave empty to auto-detect it." />
                                <Button Grid.Column="1" Content="Browse" Click="OnBrowseShad" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Classes="caption" Text="Backup folder" />
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBox Grid.Column="0" Text="{Binding BackupPath}" Margin="0,0,8,0"
                                         ToolTip.Tip="Folder where your backups are kept" />
                                <Button Grid.Column="1" Content="Browse" Click="OnBrowseBackup" Margin="0,0,8,0" />
                                <Button Grid.Column="2" Content="Open" Click="OnOpenBackupFolder" ToolTip.Tip="Open the backup folder" />
                            </Grid>
                        </StackPanel>

                        <CheckBox Content="Back up automatically before every save"
                                  IsChecked="{Binding AutoBackup}"
                                  ToolTip.Tip="Keep a timestamped backup every time you save" />

                        <Border BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="caption" Text="Credits and sources" />
                                <TextBlock Classes="caption" TextWrapping="Wrap"
                                           Text="The chalice byte format builds on the Tomb Prospectors community (DrAnger, Trin, Kazin). Dig into the research yourself:" />
                                <WrapPanel>
                                    <Button Classes="link" Content="Hex Research Central" Tag="https://docs.google.com/spreadsheets/d/1zFIzhnXHhYomlR-tFJcyk3cPywf1snqkDH900j6rtAI/edit?pli=1&amp;gid=935899711#gid=935899711"
                                            Click="OnOpenLink" Margin="0,0,16,8" />
                                    <Button Classes="link" Content="Bloodborne Wiki" Tag="https://www.bloodborne-wiki.com/"
                                            Click="OnOpenLink" Margin="0,0,16,8" />
                                    <Button Classes="link" Content="Noxde's dungeon list" Tag="https://www.nexusmods.com/bloodborne/mods/121"
                                            Click="OnOpenLink" Margin="0,0,16,8" />
                                    <Button Classes="link" Content="shadPS4" Tag="https://shadps4.net" Click="OnOpenLink" Margin="0,0,16,8" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Cancel" Click="OnShowCatalogue" />
                            <Button Classes="primary" Content="Save settings" Click="OnSaveSettings" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Backups page -->
                <Grid IsVisible="{Binding IsBackupsView}" Margin="20" RowDefinitions="Auto,*,Auto"
                      MaxWidth="900" HorizontalAlignment="Left">
                    <TextBlock Grid.Row="0" Classes="title" Text="Backups" Margin="0,0,0,16" />
                    <Border Grid.Row="1" Classes="card">
                        <Grid>
                            <ListBox Classes="plain" ItemsSource="{Binding BackupItems}" SelectedItem="{Binding SelectedBackup}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="services:BackupInfo">
                                        <StackPanel Margin="0,4">
                                            <TextBlock Classes="body" Text="{Binding DisplayName}" />
                                            <TextBlock Classes="caption" Text="{Binding Notes}"
                                                       IsVisible="{Binding Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Classes="caption" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center" Margin="24"
                                       Text="No backups yet. Use Back up now, or enable auto-backup in Settings."
                                       IsVisible="{Binding !HasBackups}" />
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
                        <Button Content="Back up now" Command="{Binding CreateBackupCommand}" IsEnabled="{Binding HasLoadedSave}"
                                ToolTip.Tip="Create a backup of the current save" />
                        <Button Content="Restore selected" Command="{Binding RestoreBackupCommand}"
                                IsEnabled="{Binding SelectedBackup, Converter={x:Static ObjectConverters.IsNotNull}}"
                                ToolTip.Tip="Replace the current save with the selected backup (the current state is backed up first)" />
                        <Button Classes="danger" Content="Delete" Click="OnDeleteBackup"
                                IsEnabled="{Binding SelectedBackup, Converter={x:Static ObjectConverters.IsNotNull}}"
                                ToolTip.Tip="Delete the selected backup" />
                        <Button Content="Open folder" Click="OnOpenBackupFolder"
                                ToolTip.Tip="Open the backup folder" />
                    </StackPanel>
                </Grid>
            </Panel>
        </Grid>

        <!-- status bar -->
        <Border Grid.Row="1" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0" Padding="20,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="13"
                           Foreground="{DynamicResource Parchment}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Classes="caption" Text="{Binding Dungeons.Count, StringFormat='{}{0} shown'}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
