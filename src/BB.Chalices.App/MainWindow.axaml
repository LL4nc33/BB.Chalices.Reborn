<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BB.Chalices.ViewModels"
        xmlns:services="using:BB.Chalices.Services"
        xmlns:entities="using:BB.Chalices.Data.Entities"
        xmlns:app="using:BB.Chalices.App"
        x:Class="BB.Chalices.App.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1366" Height="850" MinWidth="1240" MinHeight="780"
        RequestedThemeVariant="Dark"
        FontFamily="{DynamicResource GothicFont}"
        Icon="/Assets/favicon.png"
        Background="{DynamicResource WindowBg}"
        DragDrop.AllowDrop="True"
        Title="BB Chalices">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+OemPlus" Command="{Binding ZoomInCommand}" />
        <KeyBinding Gesture="Ctrl+Add" Command="{Binding ZoomInCommand}" />
        <KeyBinding Gesture="Ctrl+OemMinus" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Gesture="Ctrl+Subtract" Command="{Binding ZoomOutCommand}" />
    </Window.KeyBindings>

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="200" MaxWidth="260" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="830" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: navigation + actions -->
            <Border Grid.Column="0" x:Name="SidebarPanel" Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource Edge}" BorderThickness="0,0,1,0">
                <LayoutTransformControl>
                    <LayoutTransformControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding SidebarScale}" ScaleY="{Binding SidebarScale}" />
                    </LayoutTransformControl.LayoutTransform>
                <DockPanel Margin="20">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,20">
                        <Image Source="/Assets/favicon.png" Width="26" Height="26" VerticalAlignment="Center" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Classes="heading" Text="BB Chalices" />
                            <TextBlock Classes="caption" Text="{Binding AppVersion}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- the save lives in its own block at the bottom, with one big Save button -->
                    <StackPanel DockPanel.Dock="Bottom" Spacing="8">
                        <Border Height="1" Background="{DynamicResource Edge}" />
                        <TextBlock Classes="section" Text="CURRENT SAVE" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0" Content="Open" Click="OnOpenSaveClick" HotKey="Ctrl+O"
                                    HorizontalAlignment="Stretch" ToolTip.Tip="Open a Bloodborne save file (Ctrl+O)" />
                            <Button Grid.Column="1" Content="Detect" Command="{Binding DetectSavesCommand}"
                                    HorizontalAlignment="Stretch" ToolTip.Tip="Find your shadPS4 characters automatically" />
                        </Grid>
                        <ComboBox ItemsSource="{Binding DetectedSaves}" SelectedItem="{Binding SelectedDetectedSave}"
                                  HorizontalAlignment="Stretch" PlaceholderText="detected characters"
                                  ToolTip.Tip="Pick a detected character to load it">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DetectedSaveViewModel">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Title}" />
                                        <TextBlock Classes="caption" Text="{Binding Subtitle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding HasLoadedSave}"
                              ToolTip.Tip="The hunter's name (1-16 characters). Written on Save changes.">
                            <TextBlock Grid.Column="0" Classes="caption" Text="Hunter" VerticalAlignment="Center" Width="48" />
                            <TextBox Grid.Column="1" Text="{Binding EditableName}" MaxLength="16" VerticalAlignment="Center" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding HasLoadedSave}">
                            <TextBlock Grid.Column="0" Classes="caption" Text="Level" VerticalAlignment="Center" Width="48" />
                            <TextBox Grid.Column="1" Text="{Binding EditableLevel}" ToolTip.Tip="Character level. Written on Save changes." />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding HasLoadedSave}">
                            <TextBlock Grid.Column="0" Classes="caption" Text="Insight" VerticalAlignment="Center" Width="48" />
                            <TextBox Grid.Column="1" Text="{Binding EditableInsight}" ToolTip.Tip="Insight. Written on Save changes." />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="{Binding HasLoadedSave}">
                            <TextBlock Grid.Column="0" Classes="caption" Text="Echoes" VerticalAlignment="Center" Width="48" />
                            <TextBox Grid.Column="1" Text="{Binding EditableEchoes}" ToolTip.Tip="Blood Echoes. Written on Save changes." />
                        </Grid>
                        <TextBlock Classes="caption" Text="No save loaded"
                                   IsVisible="{Binding !HasLoadedSave}" />
                        <Button Classes="primary" Content="⚠ Fix sound crash" Command="{Binding ApplySoundFixCommand}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,4,0,0"
                                IsVisible="{Binding SoundFixNeeded}"
                                ToolTip.Tip="Your shadPS4 options file (userdata0010) isn't patched for the sound-crash fix yet. Click to apply it - a backup is made first." />
                    </StackPanel>

                    <!-- navigation between the centre views -->
                    <StackPanel VerticalAlignment="Top" Spacing="8">
                        <TextBlock Classes="section" Text="VIEWS" />
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="{DynamicResource Blood}"
                                    IsVisible="{Binding IsCatalogueView}" />
                            <Button Classes="nav" Classes.active="{Binding IsCatalogueView}" Content="Catalogue" Click="OnShowCatalogue"
                                    ToolTip.Tip="Browse and place dungeons" />
                        </Grid>
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="{DynamicResource Blood}"
                                    IsVisible="{Binding IsSettingsView}" />
                            <Button Classes="nav" Classes.active="{Binding IsSettingsView}" Content="Settings" Click="OnShowSettings"
                                    ToolTip.Tip="shadPS4 folder, auto-backup, credits and sources" />
                        </Grid>
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="{DynamicResource Blood}"
                                    IsVisible="{Binding IsBackupsView}" />
                            <Button Classes="nav" Classes.active="{Binding IsBackupsView}" Content="Backups" Click="OnShowBackups"
                                    ToolTip.Tip="Browse, restore or delete backups" />
                        </Grid>
                        <Grid>
                            <Border Width="3" HorizontalAlignment="Left" Background="{DynamicResource Blood}"
                                    IsVisible="{Binding IsGuideView}" />
                            <Button Classes="nav" Classes.active="{Binding IsGuideView}" Content="User guide" Click="OnShowGuide"
                                    ToolTip.Tip="The full manual: what everything is and how to do it, step by step" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource Edge}" Margin="0,8,0,0" />
                        <StackPanel x:Name="ZoomControls" Spacing="8">
                        <TextBlock Classes="section" Text="TEXT SIZE" Margin="0,4,0,0" />
                        <ComboBox ItemsSource="{Binding ZoomTargets}" SelectedItem="{Binding SelectedZoomTargetOption}"
                                  HorizontalAlignment="Stretch" Margin="0,0,0,4"
                                  ToolTip.Tip="Which column the - / + buttons resize. All resizes all three columns at once.">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ZoomTargetOption">
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Button Grid.Column="0" Content="-" Command="{Binding ZoomOutCommand}"
                                    FontSize="20" FontWeight="SemiBold" Width="40" HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Make the selected column smaller" />
                            <TextBlock Grid.Column="1" Text="{Binding UiScalePercent}" Classes="body"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Button Grid.Column="2" Content="+" Command="{Binding ZoomInCommand}"
                                    FontSize="20" FontWeight="SemiBold" Width="40" HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Make the selected column bigger" />
                        </Grid>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
                </LayoutTransformControl>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"
                          Background="{DynamicResource Edge}" ToolTip.Tip="Drag to resize the sidebar" />

            <!-- CENTRE/RIGHT: the content host (catalogue workspace or settings page) -->
            <!-- Transparent (not null) background so clicks on empty middle area register for click-to-target -->
            <Panel Grid.Column="2" x:Name="MiddlePanel" Background="Transparent">

                <!-- Catalogue workspace -->
                <Grid IsVisible="{Binding IsCatalogueView}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="340" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="680" MinWidth="480" />
                    </Grid.ColumnDefinitions>

                    <LayoutTransformControl Grid.Column="0">
                        <LayoutTransformControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding CatalogueScale}" ScaleY="{Binding CatalogueScale}" />
                        </LayoutTransformControl.LayoutTransform>
                    <Panel>
                    <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto,Auto" IsVisible="{Binding !ShowBuilder}">
                        <StackPanel Grid.Row="0">
                            <Border Classes="accent" IsVisible="{Binding !HasLoadedSave}" Padding="16" Margin="0,0,0,16">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="title" Text="Welcome to BB Chalices" />
                                    <TextBlock Classes="body" TextWrapping="Wrap"
                                               Text="Swap the chalice dungeons in your Bloodborne save. Drop any of 2300+ ready-made dungeons onto your altar, turn rites and effects on or off, or build your own. Every change is backed up before it is written." />
                                    <TextBlock Classes="section" Text="HOW IT WORKS" />
                                    <TextBlock Classes="body" TextWrapping="Wrap"
                                               Text="1.  Load your save: Open save or Detect saves, bottom left." />
                                    <TextBlock Classes="body" TextWrapping="Wrap"
                                               Text="2.  Pick a dungeon below. Search by boss, loot or glyph." />
                                    <TextBlock Classes="body" TextWrapping="Wrap"
                                               Text="3.  Choose a slot on the right, then Place in selected slot." />
                                    <TextBlock Classes="body" TextWrapping="Wrap"
                                               Text="4.  Tweak rites if you like, then Save changes." />
                                </StackPanel>
                            </Border>
                            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,12">
                                <TextBlock Grid.Column="0" Classes="title" Text="Lists" VerticalAlignment="Center" Margin="0,0,12,0" />
                                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <WrapPanel.Styles>
                                        <Style Selector="Button">
                                            <Setter Property="Height" Value="38" />
                                        </Style>
                                        <Style Selector="ComboBox">
                                            <Setter Property="Height" Value="38" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </WrapPanel.Styles>
                                    <Button Content="Rename" Click="OnRenameList" IsVisible="{Binding CanEditSelectedList}" Margin="0,0,6,4"
                                            ToolTip.Tip="Rename this list" />
                                    <Button Classes="danger" Content="Delete" Click="OnDeleteList" IsVisible="{Binding CanEditSelectedList}" Margin="0,0,6,4"
                                            ToolTip.Tip="Delete this list" />
                                    <ComboBox ItemsSource="{Binding Lists}" SelectedItem="{Binding SelectedList}" MinWidth="150" Margin="0,0,6,4"
                                              ToolTip.Tip="Pick a list. Nox and Community are built in; the rest are yours.">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="entities:DungeonList">
                                                <TextBlock Text="{Binding Name}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Content="+" FontSize="18" FontWeight="SemiBold" Width="34" HorizontalContentAlignment="Center" Margin="0,0,6,4"
                                            Click="OnNewList" ToolTip.Tip="Create a new list" />
                                    <Button Content="Save altar" Click="OnSaveAltarAsList" IsEnabled="{Binding HasLoadedSave}" Margin="0,0,6,4"
                                            ToolTip.Tip="Save the current altar (its filled slots) as a new list" />
                                    <Button Content="Share" Click="OnShareList" IsEnabled="{Binding SelectedListHasItems}" Margin="0,0,6,4"
                                            ToolTip.Tip="Copy this list as a share code to paste anywhere" />
                                    <Button Content="Save file" Click="OnExportListFile" IsEnabled="{Binding SelectedListHasItems}" Margin="0,0,6,4"
                                            ToolTip.Tip="Save this list as a .bbc file to share or back up" />
                                    <Button Content="Import" Click="OnImportList" Margin="0,0,0,4"
                                            ToolTip.Tip="Import a shared list from a copied code (or drop a .bbc file onto the window)" />
                                </WrapPanel>
                            </Grid>
                        </StackPanel>
                        <Grid Grid.Row="1" ColumnDefinitions="*,200" Margin="0,0,0,12">
                            <TextBox Grid.Column="0" Text="{Binding SearchText}"
                                     PlaceholderText="Search glyph, loot, gems or area" Margin="0,0,8,0"
                                     ToolTip.Tip="Filter by glyph, description, dungeon area, coffin item (e.g. Blood Rock) or gem pool (e.g. Physical)" />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                                      HorizontalAlignment="Stretch" ToolTip.Tip="Show only one category" />
                        </Grid>
                        <ListBox Grid.Row="2" Classes="plain" ItemsSource="{Binding Dungeons}" SelectedItem="{Binding SelectedDungeon}"
                                 DoubleTapped="OnCatalogueDoubleTapped" ContextRequested="OnCatalogueContextRequested">
                            <ListBox.KeyBindings>
                                <KeyBinding Gesture="Enter" Command="{Binding ApplyDungeonCommand}" />
                            </ListBox.KeyBindings>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DungeonViewModel">
                                    <StackPanel Spacing="4" ToolTip.Tip="{Binding DisplayName}">
                                        <TextBlock Classes="heading" Text="{Binding Glyph}" />
                                        <TextBlock Classes="caption accent" Text="{Binding Category}" />
                                        <TextBlock Classes="body" Text="{Binding Description}" TextWrapping="Wrap"
                                                   MaxLines="2" TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource ParchmentDim}"
                                                   IsVisible="{Binding Description, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="2" Classes="card" VerticalAlignment="Center" Padding="20"
                                IsVisible="{Binding ShowNoxDownloadPrompt}">
                            <StackPanel Spacing="12" HorizontalAlignment="Center" MaxWidth="440">
                                <TextBlock Classes="heading" Text="Nox's dungeons aren't downloaded yet" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                                <TextBlock Classes="body" TextWrapping="Wrap" TextAlignment="Center"
                                           Text="These 200+ curated dungeons are Nox's work, hosted on his gist. Fetch them once (with your OK) and they're cached for offline use. The bundled Community set works offline without them - switch to the Community tab above to browse right now." />
                                <Button Classes="primary" Content="Download from Nox's gist" Command="{Binding UpdateDungeonsCommand}"
                                        HorizontalAlignment="Center" HorizontalContentAlignment="Center"
                                        ToolTip.Tip="One-time download from Nox's gist, then cached locally for offline use" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="2" Classes="card" VerticalAlignment="Center" Padding="20"
                                IsVisible="{Binding ShowEmptyListHint}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center" MaxWidth="420">
                                <TextBlock Classes="heading" Text="This list is empty" HorizontalAlignment="Center" TextAlignment="Center" />
                                <TextBlock Classes="body" TextWrapping="Wrap" TextAlignment="Center"
                                           Text="Pick a dungeon in the Community or Nox list, then use 'add to list' to add it here. You can also import a shared list, or save the current altar as a list." />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="3" Margin="0,16,0,0" Padding="0,12,0,0"
                                BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0"
                                IsVisible="{Binding SelectedDungeon, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <StackPanel DataContext="{Binding SelectedDungeon}" x:DataType="vm:DungeonViewModel" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Classes="heading" Text="{Binding Glyph}" />
                                    <TextBlock Classes="body accent" Text="{Binding Type}" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Classes="body accent" Text="{Binding UniqueItem, StringFormat='Coffin: {0}'}"
                                           FontWeight="SemiBold" TextWrapping="Wrap"
                                           IsVisible="{Binding UniqueItem, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <TextBlock Classes="caption" Text="{Binding FavouredGems, StringFormat='Gem pool: {0}'}"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding FavouredGems, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                <TextBlock Classes="caption" Text="{Binding JoinRequirement, StringFormat='Requires: {0} chalice'}" />
                                <WrapPanel>
                                    <TextBlock Classes="caption" Text="{Binding Rites, StringFormat='Rites: {0}'}" Margin="0,0,16,0" />
                                    <TextBlock Classes="caption accent" Text="Poison"
                                               Margin="0,0,16,0" IsVisible="{Binding IsPoisoned}" />
                                    <TextBlock Classes="caption accent" Text="4th layer"
                                               IsVisible="{Binding HasFourthLayer}" />
                                </WrapPanel>
                                <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto"
                                              IsVisible="{Binding Description, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Classes="body" Text="{Binding Description}" TextWrapping="Wrap" />
                                </ScrollViewer>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button Classes="link" Content="add to list"
                                            HorizontalAlignment="Left"
                                            ToolTip.Tip="Add this dungeon to one of your lists">
                                        <Button.Flyout>
                                            <Flyout>
                                                <StackPanel MinWidth="180" Spacing="6">
                                                    <Button Content="+ New list..." Click="OnNewListAndAdd" HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Left"
                                                            ToolTip.Tip="Create a new list and add this dungeon to it" />
                                                    <ListBox x:CompileBindings="False"
                                                             ItemsSource="{Binding $parent[Window].DataContext.UserLists}"
                                                             SelectionChanged="OnAddToListPicked">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate x:DataType="entities:DungeonList">
                                                                <TextBlock Text="{Binding Name}" />
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </StackPanel>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                    <Button Classes="link" Content="remove from this list" Click="OnRemoveFromList"
                                            HorizontalAlignment="Left"
                                            IsVisible="{Binding $parent[Window].DataContext.CanEditSelectedList}"
                                            ToolTip.Tip="Remove this dungeon from the current list" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Row="4" ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8" Margin="0,16,0,0">
                            <Button Grid.Column="0" Content="Build new" Click="OnBuilderClick"
                                    IsEnabled="{Binding HasLoadedSave}"
                                    ToolTip.Tip="Generate a dungeon by area, variant and layout" />
                            <Button Grid.Column="1" Content="Fill all" Command="{Binding FillAllSlotsCommand}"
                                    IsEnabled="{Binding CanPlaceDungeon}"
                                    ToolTip.Tip="Put the selected dungeon in every slot at once (makeshift + the six stored, e.g. to farm the same gems). Save to write to disk." />
                            <Button Grid.Column="2" Content="Apply list" Click="OnApplyList"
                                    IsEnabled="{Binding CanApplyList}"
                                    ToolTip.Tip="Write the current list's dungeons onto the real six slots (then the makeshift altar). Save to write to disk." />
                            <Button Grid.Column="3" Classes="primary" Content="PLACE IN SELECTED SLOT"
                                    Command="{Binding ApplyDungeonCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    IsEnabled="{Binding CanPlaceDungeon}"
                                    ToolTip.Tip="Stage the selected dungeon in the chosen slot. Click Save changes to write it to disk." />
                        </Grid>
                    </Grid>

                    <!-- Dungeon builder, inline in the middle column (the editor stays on the right) -->
                    <ScrollViewer IsVisible="{Binding ShowBuilder}">
                        <StackPanel Margin="20" Spacing="14" DataContext="{Binding Builder}" x:DataType="vm:DungeonBuilderViewModel">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Classes="title" Text="Build a dungeon" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Classes="link" Content="back to catalogue" Click="OnCloseBuilder"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>

                            <StackPanel Spacing="6">
                                <TextBlock Classes="section" Text="AREA AND DEPTH" />
                                <ListBox Classes="plain chips" ItemsSource="{Binding Areas}" SelectedItem="{Binding SelectedArea}"
                                         ToolTip.Tip="Pick the region and depth. A valid base for it is drawn from the catalogue.">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>
                                <TextBlock Classes="caption" TextWrapping="Wrap"
                                           Text="Deeper (a higher number) means tougher enemies and better gems. Isz 5 is the usual gem-farming area." />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Classes="section" Text="VARIANT" />
                                <ListBox Classes="plain chips" ItemsSource="{Binding Variants}" SelectedItem="{Binding SelectedVariant}"
                                         ToolTip.Tip="The curse variant of the dungeon.">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>
                                <TextBlock Classes="caption" TextWrapping="Wrap"
                                           Text="Normal is the standard dungeon. Defiled is the harder cursed version with halved health. Sinister can be invaded by other players and has no 4th layer." />
                                <CheckBox Content="Use the second hundred layouts (depth 4 and 5)"
                                          IsChecked="{Binding SecondMap}" IsEnabled="{Binding SecondMapPossible}"
                                          ToolTip.Tip="Depth 4 and 5 have two sets of 100 layouts. Tick this to build from the second set." />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Classes="section" Text="LAYOUT" />
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <NumericUpDown Grid.Column="0" Minimum="0" Maximum="99" Increment="1" FormatString="0"
                                                   Value="{Binding DungeonNumber}" Width="150"
                                                   ToolTip.Tip="The layout number (0-99) picks the whole dungeon, and with it the coffin item and gem pool below. Try a few to find the loot you want." />
                                    <Button Grid.Column="2" Content="Random" Click="OnBuilderRandom"
                                            ToolTip.Tip="Jump to a random layout to roll through coffins and gems" />
                                </Grid>
                                <TextBlock Classes="caption" TextWrapping="Wrap"
                                           Text="Each layout is a different dungeon. Watch the coffin and gem pool below change as you roll." />
                            </StackPanel>

                            <Border Classes="card">
                                <StackPanel Spacing="6" Margin="4">
                                    <TextBlock Classes="section" Text="THIS DUNGEON" />
                                    <TextBlock Classes="body accent" Text="{Binding Status}" TextWrapping="Wrap" />
                                    <TextBlock Classes="body accent" FontWeight="SemiBold" TextWrapping="Wrap"
                                               Text="{Binding PreviewCoffin, StringFormat='Coffin: {0}'}"
                                               IsVisible="{Binding PreviewCoffin, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    <TextBlock Classes="caption" TextWrapping="Wrap"
                                               Text="{Binding PreviewGems, StringFormat='Gem pool: {0}'}"
                                               IsVisible="{Binding PreviewGems, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    <TextBlock Classes="caption" Text="{Binding PreviewRequires, StringFormat='Requires: {0} chalice'}" />
                                    <TextBlock Classes="caption"
                                               Text="No base for this area is in the catalogue yet."
                                               IsVisible="{Binding !CanPlace}" />
                                </StackPanel>
                            </Border>

                            <WrapPanel>
                                <Button Classes="primary" Content="Place in slot" IsEnabled="{Binding CanPlace}" Margin="0,0,8,8"
                                        ToolTip.Tip="Write this dungeon into an altar slot (the editor jumps there)">
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuItem Header="Makeshift (M)" Click="OnBuilderPlaceSlot" Tag="0" />
                                            <MenuItem Header="Slot 1" Click="OnBuilderPlaceSlot" Tag="1" />
                                            <MenuItem Header="Slot 2" Click="OnBuilderPlaceSlot" Tag="2" />
                                            <MenuItem Header="Slot 3" Click="OnBuilderPlaceSlot" Tag="3" />
                                            <MenuItem Header="Slot 4" Click="OnBuilderPlaceSlot" Tag="4" />
                                            <MenuItem Header="Slot 5" Click="OnBuilderPlaceSlot" Tag="5" />
                                            <MenuItem Header="Slot 6" Click="OnBuilderPlaceSlot" Tag="6" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                                <Button Content="Add to list" Click="OnBuilderAddToList" IsEnabled="{Binding CanPlace}" Margin="0,0,8,8"
                                        ToolTip.Tip="Add this built dungeon to one of your lists" />
                                <Button Content="Save to My dungeons" Click="OnBuilderSave" IsEnabled="{Binding CanPlace}" Margin="0,0,8,8"
                                        ToolTip.Tip="Save this built dungeon to My dungeons to reuse later" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                    </Panel>
                    </LayoutTransformControl>

                    <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"
                                  Background="{DynamicResource Edge}" ToolTip.Tip="Drag to resize the editor panel" />

                    <Border Grid.Column="2" x:Name="EditorPanel" Background="{DynamicResource BgPanel}"
                            BorderBrush="{DynamicResource Edge}" BorderThickness="1,0,0,0">
                        <LayoutTransformControl>
                            <LayoutTransformControl.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding EditorScale}" ScaleY="{Binding EditorScale}" />
                            </LayoutTransformControl.LayoutTransform>
                        <Grid Margin="20" RowDefinitions="Auto,*,Auto,Auto" IsEnabled="{Binding HasLoadedSave}">
                            <StackPanel Grid.Row="0" Spacing="8">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Column="0" Classes="section" Text="ALTAR SLOT"
                                           VerticalAlignment="Center" Margin="0,0,12,0" />
                                <ListBox Grid.Column="1" Classes="slots plain" ItemsSource="{Binding Slots}" SelectedItem="{Binding SelectedSlot}"
                                         HorizontalAlignment="Stretch" ContextRequested="OnSlotContextRequested"
                                         ToolTip.Tip="M = the makeshift altar (ritual setup), 1-6 = the stored slots. A dot marks an occupied slot. Right-click a slot for quick actions.">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SlotViewModel">
                                            <Panel ToolTip.Tip="{Binding Label}">
                                                <TextBlock Classes="heading" Text="{Binding ShortLabel}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="5" Height="5" Margin="0,0,3,0"
                                                         HorizontalAlignment="Right" VerticalAlignment="Top"
                                                         Fill="{DynamicResource BloodBright}" IsVisible="{Binding Occupied}" />
                                            </Panel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <Button Classes="link" Content="export" Click="OnCopyAltar"
                                            ToolTip.Tip="Copy the whole altar (makeshift + the six slots) as one hex string, to back up or share the loadout" />
                                    <Button Classes="link" Content="import" Click="OnPasteAltar"
                                            ToolTip.Tip="Replace the whole altar from a loadout hex string on the clipboard. Save to write to disk." />
                                </StackPanel>
                                </Grid>
                                <TextBlock Classes="heading accent" Text="{Binding SelectedSlotType}" Margin="0,8,0,0"
                                           IsVisible="{Binding SelectedSlotType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <TextBlock Classes="caption" Text="{Binding SelectedSlotJoin, StringFormat='Requires: {0} chalice'}"
                                           IsVisible="{Binding SelectedSlotJoin, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>

                            <TabControl Grid.Row="1" Margin="0,16,0,0">
                                <TabItem Header="RITES">
                                    <StackPanel Spacing="0" Margin="0,12,0,0">
                                        <ItemsControl ItemsSource="{Binding RiteSlots}" Margin="0,0,0,16">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="2" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:RiteSlotViewModel">
                                                    <Border BorderThickness="3,0,0,0" Margin="0,0,12,8" Padding="8,0,0,0"
                                                            BorderBrush="{Binding Index, Converter={x:Static app:RiteColorConverter.Instance}}"
                                                            ToolTip.Tip="Set a rite (Fetid, Rotted, Cursed or Sinister), or None to remove it">
                                                        <Grid ColumnDefinitions="44,*">
                                                            <TextBlock Grid.Column="0" Classes="caption" Text="{Binding Label}" VerticalAlignment="Center" />
                                                            <ComboBox Grid.Column="1" ItemsSource="{Binding Options}"
                                                                      SelectedItem="{Binding Rite}" HorizontalAlignment="Stretch" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Classes="section" Text="MODIFIERS"
                                                   ToolTip.Tip="Only certain dungeon types support poison, a 4th layer or a difficulty buff." />
                                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="16">
                                            <CheckBox Grid.Column="0" Content="Poison" IsChecked="{Binding PoisonEnabled}"
                                                      IsEnabled="{Binding PoisonPossible}" VerticalAlignment="Center"
                                                      ToolTip.Tip="Toggle the poison mist (only some dungeon types)" />
                                            <CheckBox Grid.Column="1" Content="Open 4th layer" IsChecked="{Binding FourthLayerOpen}"
                                                      IsEnabled="{Binding FourthLayerPossible}" VerticalAlignment="Center"
                                                      ToolTip.Tip="Open or close the optional 4th layer (only some dungeons)" />
                                            <CheckBox Grid.Column="2" Content="Difficulty up" IsChecked="{Binding DifficultyUp}"
                                                      IsEnabled="{Binding DifficultyPossible}" VerticalAlignment="Center"
                                                      ToolTip.Tip="Pthumeru 5 only: buffs enemy HP, damage and defence (byte 36)." />
                                            <Button Grid.Column="3" Classes="danger" Content="Clear slot" Command="{Binding ClearSlotCommand}"
                                                    HorizontalAlignment="Right"
                                                    ToolTip.Tip="Empty this altar slot. Click Save changes to write it to disk." />
                                        </Grid>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,8,0,0">
                                            <TextBlock Grid.Column="0" Classes="caption" Text="Special enemy" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1" HorizontalAlignment="Stretch"
                                                      ItemsSource="{Binding SpecialEnemyOptions}" SelectedItem="{Binding SelectedSpecialEnemy}"
                                                      ToolTip.Tip="Bath messengers, Patches the Spider or Beast-Possessed Souls. Sinister chalices can't spawn BPS.">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate x:CompileBindings="False">
                                                        <TextBlock Text="{Binding Converter={x:Static app:SpecialEnemyLabelConverter.Instance}}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </TabItem>
                                <TabItem Header="STRINGS">
                                    <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto"
                                                  ToolTip.Tip="Edit each headstone string as raw hex. A change applies once it is the right length.">
                                        <StackPanel Spacing="10">
                                            <TextBlock Classes="section" Text="BYTE FIELDS"
                                                       ToolTip.Tip="The numeric headstone fields (map, rites, effects). Each colour matches the byte legend." />
                                            <ItemsControl ItemsSource="{Binding ShortFields}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="2" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:HeadstoneFieldViewModel">
                                                        <Grid ColumnDefinitions="110,*" Margin="0,0,12,7" ToolTip.Tip="{Binding OffsetLabel}">
                                                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" FontSize="14"
                                                                       TextTrimming="CharacterEllipsis" Margin="0,0,8,0"
                                                                       Foreground="{Binding Offset, Converter={x:Static app:OffsetColorConverter.Instance}}" />
                                                            <TextBox Grid.Column="1" Text="{Binding Hex}" FontSize="13"
                                                                     FontFamily="Cascadia Mono,Consolas,Menlo,monospace" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Classes="section" Text="TEXT  (PSN and character name)" Margin="0,4,0,0"
                                                       ToolTip.Tip="The 16-byte creator PSN and character-name fields, as raw hex." />
                                            <ItemsControl ItemsSource="{Binding LongFields}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:HeadstoneFieldViewModel">
                                                        <Grid ColumnDefinitions="110,*" Margin="0,0,12,7" ToolTip.Tip="{Binding OffsetLabel}">
                                                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" FontSize="14"
                                                                       TextTrimming="CharacterEllipsis" Margin="0,0,8,0"
                                                                       Foreground="{Binding Offset, Converter={x:Static app:OffsetColorConverter.Instance}}" />
                                                            <TextBox Grid.Column="1" Text="{Binding Hex}" FontSize="13"
                                                                     FontFamily="Cascadia Mono,Consolas,Menlo,monospace" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>

                            <StackPanel Grid.Row="2" Spacing="8" Margin="0,16,0,0">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Classes="section" Text="LIVE BYTES" Margin="0" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14">
                                        <TextBlock Classes="caption" Text="right-click a slot to copy / paste / save"
                                                   VerticalAlignment="Center" />
                                        <Button Classes="link" Content="colour legend" Click="OnLegendClick"
                                                ToolTip.Tip="What the byte colours mean" />
                                    </StackPanel>
                                </Grid>
                                <Border Classes="hexPanel">
                                    <Panel>
                                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="190">
                                            <SelectableTextBlock app:HexView.Bytes="{Binding SelectedSlotBytes}"
                                                                 app:HexView.Baseline="{Binding SelectedSlotBaseline}"
                                                                 app:HexView.RecordStart="{Binding SelectedSlotOffset}"
                                                                 app:HexView.ShowAscii="{Binding #EditorPanel.Bounds.Width, Converter={x:Static app:WidthAtLeastConverter.Instance}, ConverterParameter=660}"
                                                                 app:HexView.ShowOffset="{Binding #EditorPanel.Bounds.Width, Converter={x:Static app:WidthAtLeastConverter.Instance}, ConverterParameter=540}"
                                                                 FontFamily="Cascadia Mono,Consolas,Menlo,monospace" FontSize="13"
                                                                 IsVisible="{Binding SlotHexDump, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </ScrollViewer>
                                        <TextBlock Classes="caption" Text="Open a save to inspect the slot's 125 bytes" VerticalAlignment="Center"
                                                   IsVisible="{Binding SlotHexDump, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                    </Panel>
                                </Border>
                            </StackPanel>

                            <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="0,16,0,0">
                                <Button Grid.Column="0" Content="Undo" Command="{Binding UndoSlotCommand}" IsEnabled="{Binding CanUndo}"
                                        ToolTip.Tip="Revert the last slot change before saving" />
                                <Button Grid.Column="1" Classes="primary" Content="SAVE CHANGES" Command="{Binding SaveCommand}"
                                        IsEnabled="{Binding HasLoadedSave}" HotKey="Ctrl+S" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        ToolTip.Tip="Write all your changes to the save file (Ctrl+S). A backup is made first." />
                            </Grid>
                        </Grid>
                        </LayoutTransformControl>
                    </Border>
                </Grid>

                <!-- Settings page -->
                <LayoutTransformControl IsVisible="{Binding IsSettingsView}">
                    <LayoutTransformControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding CatalogueScale}" ScaleY="{Binding CatalogueScale}" />
                    </LayoutTransformControl.LayoutTransform>
                <Grid ColumnDefinitions="*,Auto,320">
                    <ScrollViewer Grid.Column="0">
                        <StackPanel Margin="20" Spacing="14" MaxWidth="620" HorizontalAlignment="Left">
                            <TextBlock Classes="title" Text="Settings" />

                            <StackPanel Spacing="6">
                                <TextBlock Classes="section" Text="SHADPS4 FOLDER" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" Text="{Binding ShadPs4Path}" Margin="0,0,8,0"
                                             PlaceholderText="leave empty to auto-detect"
                                             ToolTip.Tip="Your shadPS4 folder. Leave empty to auto-detect it." />
                                    <Button Grid.Column="1" Content="Browse" Click="OnBrowseShad" />
                                </Grid>
                                <TextBlock Classes="caption" Text="{Binding DetectedShadInfo}" TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Classes="section" Text="SHADPS4 FIXES" />
                                <Button Content="Fix sound crash" Command="{Binding ApplySoundFixCommand}" HorizontalAlignment="Left"
                                        ToolTip.Tip="Applies the shadPS4 sound-crash workaround: sets userdata0010 offset 0x204E to 01. A backup is made first." />
                                <TextBlock Classes="caption" TextWrapping="Wrap"
                                           Text="Patches the options file (userdata0010) to stop the shadPS4 audio crash, for any build. Credit: imbal4nc3d, with proteh." />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Classes="section" Text="DUNGEON CATALOGUE" />
                                <Button Content="Download / update from Nox's gist" Command="{Binding UpdateDungeonsCommand}" HorizontalAlignment="Left"
                                        ToolTip.Tip="Fetch the latest catalogue from Nox's gist and cache it locally for offline use." />
                                <TextBlock Classes="caption" TextWrapping="Wrap"
                                           Text="The 200+ ready-made dungeons are Nox's work, fetched from his gist with your consent and cached locally. The app works offline without them." />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button Content="Cancel" Click="OnShowCatalogue" />
                                <Button Classes="primary" Content="Save settings" Click="OnSaveSettings" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"
                                  Background="{DynamicResource Edge}" ToolTip.Tip="Drag to resize the info panel" />

                    <Border Grid.Column="2" Background="{DynamicResource BgPanel}"
                            BorderBrush="{DynamicResource Edge}" BorderThickness="1,0,0,0">
                        <ScrollViewer>
                            <StackPanel Margin="20" Spacing="18">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="section" Text="ABOUT" />
                                    <TextBlock Classes="heading" Text="BB Chalices" />
                                    <TextBlock Classes="caption" Text="{Binding AppVersion}" />
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Classes="section" Text="DATA FOLDER" />
                                    <TextBlock Classes="caption" Text="{Binding DataFolder}" TextWrapping="Wrap" />
                                    <TextBlock Classes="caption" Text="{Binding StorageModeText}" TextWrapping="Wrap" />
                                    <Button Content="Open data folder" Click="OnOpenDataFolder" HorizontalAlignment="Left" Margin="0,4,0,0" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock Classes="section" Text="CREDITS AND SOURCES" />
                                    <TextBlock Classes="caption" TextWrapping="Wrap"
                                               Text="The chalice byte format builds on the Tomb Prospectors community (DrAnger, Trin, Kazin)." />
                                    <StackPanel Spacing="2">
                                        <Button Classes="link" Content="Hex Research Central" HorizontalAlignment="Left"
                                                Tag="https://docs.google.com/spreadsheets/d/1zFIzhnXHhYomlR-tFJcyk3cPywf1snqkDH900j6rtAI/edit?pli=1&amp;gid=935899711#gid=935899711" Click="OnOpenLink" />
                                        <Button Classes="link" Content="Bloodborne Wiki" HorizontalAlignment="Left"
                                                Tag="https://www.bloodborne-wiki.com/" Click="OnOpenLink" />
                                        <Button Classes="link" Content="Nox's dungeon list" HorizontalAlignment="Left"
                                                Tag="https://www.nexusmods.com/bloodborne/mods/121" Click="OnOpenLink" />
                                        <Button Classes="link" Content="shadPS4" HorizontalAlignment="Left"
                                                Tag="https://shadps4.net" Click="OnOpenLink" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
                </LayoutTransformControl>

                <!-- Backups page -->
                <LayoutTransformControl IsVisible="{Binding IsBackupsView}">
                    <LayoutTransformControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding CatalogueScale}" ScaleY="{Binding CatalogueScale}" />
                    </LayoutTransformControl.LayoutTransform>
                <Grid ColumnDefinitions="*,Auto,320">
                    <Grid Grid.Column="0" Margin="20" RowDefinitions="Auto,*">
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                            <TextBlock Classes="title" Text="Backups" />
                            <TextBlock Classes="caption" Text="{Binding BackupSummary}" VerticalAlignment="Bottom" Margin="0,0,0,4" />
                        </StackPanel>
                        <Border Grid.Row="1" Classes="card" Padding="0">
                            <Grid RowDefinitions="Auto,*">
                                <Grid Grid.Row="0" ColumnDefinitions="*,105,80,1.5*" Margin="15,10,12,6"
                                      IsVisible="{Binding HasBackups}">
                                    <TextBlock Grid.Column="0" Classes="section" Text="FILE" Margin="0" />
                                    <TextBlock Grid.Column="1" Classes="section" Text="DATE" Margin="0" />
                                    <TextBlock Grid.Column="2" Classes="section" Text="TIME" Margin="0" />
                                    <TextBlock Grid.Column="3" Classes="section" Text="NOTE" Margin="0" />
                                </Grid>
                                <ListBox Grid.Row="1" Classes="plain table" ItemsSource="{Binding BackupItems}" SelectedItem="{Binding SelectedBackup}"
                                         ContextRequested="OnBackupContextRequested"
                                         DoubleTapped="OnBackupDoubleTapped">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="services:BackupInfo">
                                            <Grid ColumnDefinitions="*,105,80,1.5*">
                                                <TextBlock Grid.Column="0" Classes="body" Text="{Binding OriginalFile}"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Classes="caption" VerticalAlignment="Center"
                                                           Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}" />
                                                <TextBlock Grid.Column="2" Classes="caption" VerticalAlignment="Center"
                                                           Text="{Binding Date, StringFormat='{}{0:HH:mm:ss}'}" />
                                                <TextBlock Grid.Column="3" Classes="caption" VerticalAlignment="Center"
                                                           Text="{Binding Notes}" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Grid.Row="1" Classes="caption" VerticalAlignment="Center" HorizontalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center" Margin="24"
                                           Text="No backups yet. Use Back up now, or turn on auto-backup on the right."
                                           IsVisible="{Binding !HasBackups}" />
                            </Grid>
                        </Border>
                    </Grid>

                    <GridSplitter Grid.Column="1" Width="5" ResizeDirection="Columns"
                                  Background="{DynamicResource Edge}" ToolTip.Tip="Drag to resize the details panel" />

                    <Border Grid.Column="2" Background="{DynamicResource BgPanel}"
                            BorderBrush="{DynamicResource Edge}" BorderThickness="1,0,0,0">
                        <ScrollViewer>
                        <StackPanel Margin="20" Spacing="18">
                            <Button Content="Back up now" Command="{Binding CreateBackupCommand}" IsEnabled="{Binding HasLoadedSave}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Create a backup of the current save right now" />

                            <StackPanel Spacing="12">
                                <TextBlock Classes="section" Text="BACKUP DETAILS" />
                                <TextBlock Classes="caption" TextWrapping="Wrap"
                                           Text="Select a backup on the left to see its details."
                                           IsVisible="{Binding SelectedBackup, Converter={x:Static ObjectConverters.IsNull}}" />
                                <StackPanel Spacing="12"
                                            IsVisible="{Binding SelectedBackup, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Classes="heading" Text="{Binding SelectedBackup.OriginalFile}" TextWrapping="Wrap" />
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="section" Text="WHEN" />
                                        <TextBlock Classes="caption" Text="{Binding SelectedBackup.Date, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" />
                                    </StackPanel>
                                    <StackPanel Spacing="2" IsVisible="{Binding SelectedBackup.Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Classes="section" Text="NOTE" />
                                        <TextBlock Classes="caption" Text="{Binding SelectedBackup.Notes}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="section" Text="FILE" />
                                        <TextBlock Classes="caption" Text="{Binding SelectedBackup.FilePath}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Spacing="8" Margin="0,4,0,0">
                                        <Button Classes="primary" Content="Restore this backup" Click="OnRestoreBackup"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                ToolTip.Tip="Replace the current save with this backup (the current state is backed up first)" />
                                        <Button Classes="danger" Content="Delete" Click="OnDeleteBackup"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                ToolTip.Tip="Delete this backup" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <Border BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="section" Text="BACKUP FOLDER" />
                                    <TextBox Text="{Binding BackupPath}" IsReadOnly="True"
                                             ToolTip.Tip="Folder where your backups are kept" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button Content="Browse" Click="OnBrowseBackup" />
                                        <Button Content="Open" Click="OnOpenBackupFolder" ToolTip.Tip="Open the backup folder" />
                                    </StackPanel>
                                    <CheckBox Content="Back up automatically before every save"
                                              IsChecked="{Binding AutoBackup}" IsCheckedChanged="OnAutoBackupChanged"
                                              ToolTip.Tip="Keep a timestamped backup every time you save" />
                                    <TextBlock Classes="caption" TextWrapping="Wrap"
                                               Text="On: a timestamped copy is kept here, listed on the left. Off: a single rolling backup/ folder is kept next to the save instead. Either way you get one backup per save, never two." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
                </LayoutTransformControl>

                <!-- User guide: a full workshop-style manual, contents on the left -->
                <LayoutTransformControl IsVisible="{Binding IsGuideView}">
                    <LayoutTransformControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding CatalogueScale}" ScaleY="{Binding CatalogueScale}" />
                    </LayoutTransformControl.LayoutTransform>
                <Grid ColumnDefinitions="Auto,*">

                    <!-- Contents -->
                    <Border Grid.Column="0" Width="250" Background="{DynamicResource BgPanel}"
                            BorderBrush="{DynamicResource Edge}" BorderThickness="0,0,1,0">
                        <ScrollViewer>
                            <StackPanel Margin="20" Spacing="1" TextElement.FontFamily="Georgia, Cambria, 'Times New Roman', serif">
                                <TextBlock Classes="section" Text="CONTENTS" />
                                <Button Classes="toc" Tag="Ch1" Click="OnGuideNavigate" Content="1  Before you begin" />
                                <Button Classes="toc" Tag="Ch2" Click="OnGuideNavigate" Content="2  Getting started" />
                                <Button Classes="toc" Tag="Ch3" Click="OnGuideNavigate" Content="3  Bloodborne in five minutes" />
                                <Button Classes="toc" Tag="Ch4" Click="OnGuideNavigate" Content="4  The catalogue and your lists" />
                                <Button Classes="toc" Tag="Ch5" Click="OnGuideNavigate" Content="5  Placing dungeons on the altar" />
                                <Button Classes="toc" Tag="Ch6" Click="OnGuideNavigate" Content="6  Building your own dungeon" />
                                <Button Classes="toc" Tag="Ch7" Click="OnGuideNavigate" Content="7  The editor" />
                                <Button Classes="toc" Tag="Ch8" Click="OnGuideNavigate" Content="8  Sharing dungeons and lists" />
                                <Button Classes="toc" Tag="Ch9" Click="OnGuideNavigate" Content="9  Backups and safety" />
                                <Button Classes="toc" Tag="Ch10" Click="OnGuideNavigate" Content="10  Settings" />
                                <Button Classes="toc" Tag="Ch11" Click="OnGuideNavigate" Content="11  If something goes wrong" />
                                <Button Classes="toc" Tag="Ch12" Click="OnGuideNavigate" Content="12  A word on the numbers" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- The manual itself -->
                    <ScrollViewer Grid.Column="1">
                        <StackPanel Margin="40,28,40,60" MaxWidth="840" HorizontalAlignment="Left" Spacing="0"
                                    TextElement.FontFamily="Georgia, Cambria, 'Times New Roman', serif">

                            <TextBlock Classes="manualH1" Text="BB.Chalices Reborn" />
                            <TextBlock Classes="section" Text="OWNER'S MANUAL AND WORKSHOP GUIDE" Margin="0,4,0,14" />
                            <TextBlock Classes="manualLede" TextWrapping="Wrap"
                                       Text="This book is here to keep your chalice dungeons alive. It walks you from opening a save through placing, building and sharing dungeons, and it never assumes you have done any of this before. Read it front to back the first time, or jump to a chapter from the list on the left. Nothing you do here touches your game until you press Save changes, and a backup is always made first. So relax, and let us get to work." />

                            <TextBlock x:Name="Ch1" Classes="manualH2" Text="1  Before you begin" />
                            <TextBlock Classes="manualH3" Text="What this tool is" />
                            <TextBlock Classes="manualBody"
                                       Text="BB.Chalices Reborn is an editor for the chalice-dungeon altar in a Bloodborne save. Your altar has six stored slots plus one makeshift slot. This tool lets you drop hand-picked dungeons into those slots, build fresh ones, keep them in named lists, and swap them with other players. It is meant for shadPS4, the PlayStation 4 emulator." />
                            <TextBlock Classes="manualH3" Text="Where your files live" />
                            <TextBlock Classes="manualBody"
                                       Text="The app is portable. Everything it owns - its settings, the dungeon catalogue, and your backups - sits in a folder named data next to the program. Move the program folder to a USB stick and your whole setup travels with it. Nothing is written to hidden corners of your system." />
                            <Border Classes="manualNote">
                                <TextBlock Classes="manualBody" Margin="0"
                                           Text="Golden rule: the app only writes to your save when you press Save changes, and it copies the old save into Backups first. If a change ever looks wrong, you can put the old one back in two clicks (Chapter 9)." />
                            </Border>

                            <TextBlock x:Name="Ch2" Classes="manualH2" Text="2  Getting started" />
                            <TextBlock Classes="manualH3" Text="Opening your save" />
                            <TextBlock Classes="manualBody"
                                       Text="Look at the bottom-left of the window, under CURRENT SAVE. You have two ways in:" />
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">1</Run><Run Text="  Detect finds your shadPS4 characters by itself. Press it, then pick a character from the drop-down. This is the easy road." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">2</Run><Run Text="  Open (Ctrl+O) lets you point straight at a save file if you keep it somewhere unusual." /></TextBlock>
                            <TextBlock Classes="manualBody"
                                       Text="Once a save is loaded, its hunter name, level, insight and blood echoes appear at the top-left. You can edit these too; like everything else, they are written only when you Save changes." />
                            <TextBlock Classes="manualH3" Text="The sound-crash fix" />
                            <TextBlock Classes="manualBody"
                                       Text="shadPS4 can crash on the chalice-dungeon sound unless a small option file is patched. If your save's folder still needs it, a red Fix sound crash button appears at the top-left. Press it once. It patches the option file for every character it finds and backs each one up first. When the button disappears, you are done." />
                            <TextBlock Classes="manualH3" Text="Reading the window" />
                            <TextBlock Classes="manualBody"
                                       Text="The window has three columns. The left is the sidebar: navigation, text size, and the save controls. The middle is your workspace: the catalogue, or the dungeon builder. The right is the editor, showing whichever altar slot you are working on. You can drag the dividers between columns to resize them, and set the text size of each column independently in the sidebar under TEXT SIZE." />

                            <TextBlock x:Name="Ch3" Classes="manualH2" Text="3  Bloodborne in five minutes" />
                            <TextBlock Classes="manualBody"
                                       Text="If you already know your Depth 5 root chalices from your Fetid rites, skip ahead. If not, here is everything the rest of this book leans on." />
                            <TextBlock Classes="manualH3" Text="The altar and its slots" />
                            <TextBlock Classes="manualBody"
                                       Text="In the game you place a chalice on an altar to open a dungeon. Your save keeps six of these altar slots plus one makeshift slot (shown as M here). This tool writes dungeons into those seven places. A slot can hold one dungeon or be empty." />
                            <TextBlock Classes="manualH3" Text="Coffins - the loot" />
                            <TextBlock Classes="manualBody"
                                       Text="Many dungeons have a special coffin holding a fixed reward: a rune, a weapon, a specific blood gem. When a dungeon has a known coffin, this tool names it for you, so you can hunt the exact item you want instead of guessing from raw numbers." />
                            <TextBlock Classes="manualH3" Text="Blood gems and gem pools" />
                            <TextBlock Classes="manualBody"
                                       Text="The deep dungeons are where players farm blood gems to strengthen weapons. Each dungeon draws its gems from a pool, and the tool shows that pool as the gem pool. This is the heart of gem farming: pick a dungeon whose pool holds the gem you are chasing." />
                            <TextBlock Classes="manualH3" Text="Depth and area" />
                            <TextBlock Classes="manualBody"
                                       Text="Dungeons run from Depth 1 to Depth 5. Deeper means tougher enemies and better rewards. The area (Pthumeru, Hintertomb, Loran, Isz) sets the flavour and which gems appear. Isz Depth 5 is the classic gem-farming ground." />
                            <TextBlock Classes="manualH3" Text="Variants: Normal, Defiled, Sinister" />
                            <TextBlock Classes="manualBody"
                                       Text="Normal is the plain dungeon. Defiled is a cursed version: harder, and your health is halved throughout. Sinister dungeons can be invaded by other players and drop the fourth boss layer. The tool can build any of the three." />
                            <TextBlock Classes="manualH3" Text="Glyphs" />
                            <TextBlock Classes="manualBody"
                                       Text="Every shared dungeon in the game has a glyph, a short code like 8pwunh82. In the catalogue you can search by glyph to find a specific known dungeon in an instant." />

                            <TextBlock x:Name="Ch4" Classes="manualH2" Text="4  The catalogue and your lists" />
                            <TextBlock Classes="manualBody"
                                       Text="The middle column is your catalogue: a browsable shelf of dungeons. Above it sits the list picker, which decides which shelf you are looking at." />
                            <TextBlock Classes="manualH3" Text="Searching" />
                            <TextBlock Classes="manualBody"
                                       Text="Type in the search box to filter by boss, loot, dungeon type or glyph. Clear it to see the whole list again. Click any dungeon to select it; its details (coffin, gem pool, requirements) appear below." />
                            <TextBlock Classes="manualH3" Text="What the lists are" />
                            <TextBlock Classes="manualBody"
                                       Text="A list is just a named shelf of dungeons. Two lists are built in and always present: Nox (a curated farming set) and Community (the wider catalogue). You cannot edit those two, which keeps them safe. Every other list is yours to shape. My dungeons is where your own saved and built dungeons collect." />
                            <TextBlock Classes="manualH3" Text="Making and managing lists" />
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">1</Run><Run Text="  Press the + button next to the list picker to create a new, empty list and name it." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">2</Run><Run Text="  With one of your own lists chosen, Rename and Delete appear. Built-in lists never show them." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">3</Run><Run Text="  To add the selected dungeon to a list, use its add to list link, or right-click it in the catalogue. You can create a new list on the spot from the same menu." /></TextBlock>
                            <TextBlock Classes="manualH3" Text="Applying a list to your altar" />
                            <TextBlock Classes="manualBody"
                                       Text="Apply list (below the catalogue) writes a list's dungeons onto your altar in order: the six stored slots first, then the makeshift slot. It is the fastest way to load a whole farming set at once. As always, nothing reaches disk until you Save changes." />

                            <TextBlock x:Name="Ch5" Classes="manualH2" Text="5  Placing dungeons on the altar" />
                            <TextBlock Classes="manualBody" Text="There are three ways to get a dungeon into a slot. Pick whichever suits the moment." />
                            <TextBlock Classes="manualH3" Text="Into one chosen slot" />
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">1</Run><Run Text="  Select a dungeon in the catalogue." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">2</Run><Run Text="  On the right, click the slot you want (M or 1 to 6)." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">3</Run><Run Text="  Press PLACE IN SELECTED SLOT. Or skip the slot buttons and right-click the dungeon, then choose Place in slot for a slot menu." /></TextBlock>
                            <TextBlock Classes="manualH3" Text="Into every slot at once" />
                            <TextBlock Classes="manualBody"
                                       Text="Fill all drops the selected dungeon into all seven places. Handy when you want to farm the same gems and do not care which slot you enter." />
                            <TextBlock Classes="manualH3" Text="Keeping a slot you like" />
                            <TextBlock Classes="manualBody"
                                       Text="Right-click any altar slot to copy it, paste another dungeon over it, clear it, or Save to My dungeons so you can find that exact dungeon again later. When you place a dungeon, the editor jumps to that slot so you can see what landed." />

                            <TextBlock x:Name="Ch6" Classes="manualH2" Text="6  Building your own dungeon" />
                            <TextBlock Classes="manualBody"
                                       Text="Press Build new (below the catalogue) and the middle column becomes a workbench. The editor stays on the right, so you can place what you build straight away." />
                            <TextBlock Classes="manualH3" Text="Step by step" />
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">1</Run><Run Text="  Pick an Area and depth from the chips. The chosen one lights up red." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">2</Run><Run Text="  Pick a Variant: Normal, Defiled or Sinister. On Depth 4 and 5 you can also tick the second layout set for a hundred more dungeons." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">3</Run><Run Text="  Set the Layout number, or press Random. This is the dial that changes the whole dungeon, and with it the coffin and gem pool shown in the preview." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">4</Run><Run Text="  Read the preview card. Watch the Coffin and Gem pool lines. Roll Random until you see the loot you want." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">5</Run><Run Text="  Send it out: Place in slot puts it on the altar, Add to list files it away, and Save to My dungeons keeps it under a name. Use back to catalogue when you are done." /></TextBlock>
                            <Border Classes="manualNote">
                                <TextBlock Classes="manualBody" Margin="0"
                                           Text="Farming tip: fix the area and variant, then spin Random and watch the gem pool. When it names your gem, place it and go. This is the quickest path to a farming dungeon." />
                            </Border>

                            <TextBlock x:Name="Ch7" Classes="manualH2" Text="7  The editor" />
                            <TextBlock Classes="manualBody"
                                       Text="The right column edits whichever slot is selected. It has two tabs." />
                            <TextBlock Classes="manualH3" Text="Rites" />
                            <TextBlock Classes="manualBody"
                                       Text="Rites are the modifiers stamped on a dungeon: cursed, fetid, rotted and the rest. Toggle them here to change how a placed dungeon behaves without rebuilding it from scratch." />
                            <TextBlock Classes="manualH3" Text="Strings" />
                            <TextBlock Classes="manualBody"
                                       Text="The Strings tab shows the readable text fields tied to the slot. Most players never need it, but it is there when you do." />
                            <TextBlock Classes="manualH3" Text="Live bytes" />
                            <TextBlock Classes="manualBody"
                                       Text="At the bottom the editor shows the raw 125 bytes of the slot, updating as you change things. It is a window onto the truth of the save. To copy, paste or save those bytes, right-click the slot (Chapter 5); the old on-screen buttons were retired in favour of that menu." />

                            <TextBlock x:Name="Ch8" Classes="manualH2" Text="8  Sharing dungeons and lists" />
                            <TextBlock Classes="manualBody"
                                       Text="Sharing works entirely offline. No server, no account: a dungeon or a whole list turns into a short code you can send by any means, and back again." />
                            <TextBlock Classes="manualH3" Text="Sending" />
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">1</Run><Run Text="  Share copies the current list as a code to your clipboard. Paste it into a chat, a forum, anywhere. To share a single dungeon, right-click it and choose Copy as code." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">2</Run><Run Text="  Save file writes the list to a .bbc file instead, good for a permanent copy or a large set." /></TextBlock>
                            <TextBlock Classes="manualH3" Text="Receiving" />
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">1</Run><Run Text="  Press Import and paste a code someone sent you. The dungeons arrive as a fresh list." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">2</Run><Run Text="  Or simply drag a .bbc file onto the window. Same result, no dialog." /></TextBlock>
                            <TextBlock Classes="manualBody"
                                       Text="Imported dungeons are just data; they cannot harm your save. They sit in a list until you choose to place them." />

                            <TextBlock x:Name="Ch9" Classes="manualH2" Text="9  Backups and safety" />
                            <TextBlock Classes="manualBody"
                                       Text="This is the chapter that lets you experiment without fear. Open the Backups tab from the sidebar." />
                            <TextBlock Classes="manualH3" Text="How backups happen" />
                            <TextBlock Classes="manualBody"
                                       Text="With auto-backup on (the default), every save first tucks a timestamped copy into your Backups folder, listed in the table. With it off, a single rolling backup is kept next to the save instead. Either way you get exactly one backup per save, never two. You can also press Back up now at any time." />
                            <TextBlock Classes="manualH3" Text="Restoring" />
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">1</Run><Run Text="  Pick a backup in the table. Its details show on the right." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">2</Run><Run Text="  Press Restore this backup. The current save is itself backed up first, then replaced. You can also right-click a row to restore or delete it." /></TextBlock>
                            <TextBlock Classes="manualH3" Text="The backup folder" />
                            <TextBlock Classes="manualBody"
                                       Text="By default backups live in a Backups folder inside the app's data folder, so they travel with the portable app. You can point them elsewhere with Browse if you prefer." />

                            <TextBlock x:Name="Ch10" Classes="manualH2" Text="10  Settings" />
                            <TextBlock Classes="manualBody"
                                       Text="The Settings tab holds the few things you set once and forget." />
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">-</Run><Run Text="  shadPS4 folder: where your emulator keeps its saves. Set it if auto-detect cannot find them; otherwise leave it be." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">-</Run><Run Text="  Dungeon catalogue: the source the catalogue is seeded from. Most people never touch this." /></TextBlock>
                            <TextBlock Classes="manualBody"><Run FontWeight="Bold" Foreground="{DynamicResource BloodBright}">-</Run><Run Text="  Text size lives in the sidebar, not here: the drop-down chooses which column the minus and plus buttons resize, or All for every column at once." /></TextBlock>

                            <TextBlock x:Name="Ch11" Classes="manualH2" Text="11  If something goes wrong" />
                            <TextBlock Classes="manualH3" Text="Detect finds nothing" />
                            <TextBlock Classes="manualBody"
                                       Text="Set the shadPS4 folder in Settings, then Detect again. Or use Open to point straight at the save file." />
                            <TextBlock Classes="manualH3" Text="The game still crashes on dungeon sound" />
                            <TextBlock Classes="manualBody"
                                       Text="Load a character and look for the red Fix sound crash button at the top-left. If it is showing, press it. If it is not, the fix is already in place." />
                            <TextBlock Classes="manualH3" Text="A change looks wrong in-game" />
                            <TextBlock Classes="manualBody"
                                       Text="Go to Backups, pick the copy from just before your change, and Restore this backup. Because every save is backed up, there is always a way back." />
                            <TextBlock Classes="manualH3" Text="An import did nothing" />
                            <TextBlock Classes="manualBody"
                                       Text="Make sure you copied the whole code, including its prefix. A partial code cannot be read. For big sets, ask for the .bbc file and drag it onto the window instead." />

                            <TextBlock x:Name="Ch12" Classes="manualH2" Text="12  A word on the numbers" />
                            <TextBlock Classes="manualBody"
                                       Text="Under every friendly name in this app is a small, exact piece of the save: each dungeon is 125 bytes, each slot a fixed place in the file. This tool's whole job is to change those bytes correctly and leave the rest untouched. That is why it always backs up first, why it writes only when you tell it to, and why it shows you the live bytes: so you can trust what it does. Treat your saves kindly, keep a backup, and enjoy the hunt." />

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                </LayoutTransformControl>
            </Panel>
        </Grid>

        <!-- status bar (scales with the catalogue/main-content zoom, so "All" grows it too) -->
        <Border Grid.Row="1" Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0" Padding="20,8">
            <LayoutTransformControl>
                <LayoutTransformControl.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding CatalogueScale}" ScaleY="{Binding CatalogueScale}" />
                </LayoutTransformControl.LayoutTransform>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="14"
                               Foreground="{DynamicResource Parchment}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Classes="caption" Text="{Binding Dungeons.Count, StringFormat='{}{0} shown'}"
                               VerticalAlignment="Center" />
                </Grid>
            </LayoutTransformControl>
        </Border>
    </Grid>
</Window>
