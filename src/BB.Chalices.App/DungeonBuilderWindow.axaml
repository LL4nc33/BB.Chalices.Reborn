<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BB.Chalices.ViewModels"
        x:Class="BB.Chalices.App.DungeonBuilderWindow"
        x:DataType="vm:DungeonBuilderViewModel"
        Width="620" Height="640" MinWidth="560" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        RequestedThemeVariant="Dark"
        FontFamily="{DynamicResource GothicFont}"
        Background="{DynamicResource BgBase}"
        Icon="/Assets/favicon.png"
        Title="Dungeon builder">

    <Grid Margin="24" RowDefinitions="Auto,*,Auto">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,18">
            <TextBlock Grid.Column="0" Text="Dungeon builder" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource Parchment}" />
            <TextBlock Grid.Column="1" Text="{Binding StepLabel}" VerticalAlignment="Center"
                       Foreground="{DynamicResource ParchmentDim}" />
        </Grid>

        <Grid Grid.Row="1">

            <!-- Step 1: area and depth -->
            <StackPanel IsVisible="{Binding IsAreaStep}" Spacing="14">
                <TextBlock Classes="section" Text="WHERE AND HOW DEEP" />
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource ParchmentDim}"
                           Text="Every chalice dungeon belongs to an area (Pthumeru, Hintertomb, Loran or Isz) and a depth from 1 to 5. Deeper dungeons have tougher enemies and better loot. Pick where you want to go." />
                <ComboBox ItemsSource="{Binding Areas}" SelectedItem="{Binding SelectedArea}" HorizontalAlignment="Stretch"
                          ToolTip.Tip="Sets the area byte and draws a valid base dungeon from the catalogue" />
            </StackPanel>

            <!-- Step 2: layout -->
            <StackPanel IsVisible="{Binding IsLayoutStep}" Spacing="12">
                <TextBlock Classes="section" Text="WHICH LAYOUT" />
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource ParchmentDim}"
                           Text="Each area has a fixed set of layouts (100, or 200 for depth 4 and 5). Pick a layout number, and optionally a variant: Defiled is a harder cursed version, Sinister can be invaded and has no 4th layer." />
                <Grid ColumnDefinitions="120,*">
                    <TextBlock Grid.Column="0" Text="Variant" VerticalAlignment="Center" Foreground="{DynamicResource Parchment}" />
                    <ComboBox Grid.Column="1" ItemsSource="{Binding Variants}" SelectedItem="{Binding SelectedVariant}"
                              HorizontalAlignment="Stretch" />
                </Grid>
                <CheckBox Content="Use the second hundred layouts (depth 4 and 5)"
                          IsChecked="{Binding SecondMap}" IsEnabled="{Binding SecondMapPossible}" />
                <Grid ColumnDefinitions="120,*">
                    <TextBlock Grid.Column="0" Text="Layout number" VerticalAlignment="Center" Foreground="{DynamicResource Parchment}" />
                    <NumericUpDown Grid.Column="1" Minimum="0" Maximum="99" Increment="1" FormatString="0"
                                   Value="{Binding DungeonNumber}" HorizontalAlignment="Left" Width="140" />
                </Grid>
                <Border Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource Edge}" BorderThickness="1" Padding="12,10">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" MaxHeight="210">
                        <SelectableTextBlock Text="{Binding PreviewHex}"
                                             FontFamily="Cascadia Mono,Consolas,Menlo,monospace" FontSize="12"
                                             Foreground="{DynamicResource Parchment}" />
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Step 3: review and place -->
            <StackPanel IsVisible="{Binding IsPlaceStep}" Spacing="14">
                <TextBlock Classes="section" Text="REVIEW AND PLACE" />
                <TextBlock Text="{Binding Status}" Foreground="{DynamicResource BloodBright}" FontSize="14" />
                <Border Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource Edge}" BorderThickness="1" Padding="12,10">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" MaxHeight="240">
                        <SelectableTextBlock Text="{Binding PreviewHex}"
                                             FontFamily="Cascadia Mono,Consolas,Menlo,monospace" FontSize="12"
                                             Foreground="{DynamicResource Parchment}" />
                    </ScrollViewer>
                </Border>
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ParchmentDim}"
                           Text="This is written into the slot selected in the main window. Set rites, poison and the 4th layer there afterwards." />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,18,0,0">
            <Button Grid.Column="0" Content="Where this comes from" Click="OnLearnMore"
                    Foreground="{DynamicResource ParchmentDim}" Background="Transparent" BorderThickness="0" Padding="0"
                    ToolTip.Tip="The Tomb Prospectors data-mining the byte format builds on" />
            <Button Grid.Column="1" Content="Back" Click="OnBack" IsVisible="{Binding CanGoBack}" HorizontalAlignment="Right" Margin="0,0,8,0" />
            <Button Grid.Column="2" Content="Next" Click="OnNext" IsVisible="{Binding !IsPlaceStep}" />
            <Button Grid.Column="2" Classes="primary" Content="Place in selected slot" Click="OnPlace" IsVisible="{Binding IsPlaceStep}" />
            <Button Grid.Column="3" Content="Close" Click="OnClose" Margin="8,0,0,0" />
        </Grid>
    </Grid>
</Window>
