<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BB.Chalices.App.SettingsWindow"
        Width="560" Height="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        RequestedThemeVariant="Dark"
        FontFamily="{DynamicResource GothicFont}"
        Background="{DynamicResource BgBase}"
        Icon="/Assets/favicon.png"
        Title="Settings">

    <StackPanel Margin="22" Spacing="16">
        <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Parchment}" />

        <StackPanel Spacing="4">
            <TextBlock Text="shadPS4 folder" Foreground="{DynamicResource ParchmentDim}" />
            <Grid ColumnDefinitions="*,Auto">
                <TextBox x:Name="ShadBox" Grid.Column="0" PlaceholderText="leave empty to auto-detect" Margin="0,0,8,0"
                         ToolTip.Tip="Your shadPS4 folder. Leave empty to auto-detect it." />
                <Button Grid.Column="1" Content="Browse…" Click="OnBrowseShad" />
            </Grid>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Backup folder" Foreground="{DynamicResource ParchmentDim}" />
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox x:Name="BackupBox" Grid.Column="0" Margin="0,0,8,0"
                         ToolTip.Tip="Folder where your backups are kept" />
                <Button Grid.Column="1" Content="Browse…" Click="OnBrowseBackup" Margin="0,0,8,0" />
                <Button Grid.Column="2" Content="Open" Click="OnOpenBackup" ToolTip.Tip="Open the backup folder" />
            </Grid>
        </StackPanel>

        <CheckBox x:Name="AutoBackupBox" Content="Back up automatically before every save"
                  Foreground="{DynamicResource Parchment}"
                  ToolTip.Tip="Keep a timestamped backup every time you save" />

        <Border BorderBrush="{DynamicResource Edge}" BorderThickness="0,1,0,0" Padding="0,14,0,0">
            <StackPanel Spacing="8">
                <TextBlock Text="Credits and sources" Foreground="{DynamicResource ParchmentDim}" />
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ParchmentDim}"
                           Text="The chalice byte format builds on the Tomb Prospectors community (DrAnger, Trin, Kazin). Dig into the research yourself:" />
                <WrapPanel>
                    <Button Content="Hex Research Central" Tag="https://www.bloodborne-wiki.com/2017/12/data-mining.html"
                            Click="OnOpenLink" Margin="0,0,8,8" />
                    <Button Content="Bloodborne Wiki" Tag="https://www.bloodborne-wiki.com/"
                            Click="OnOpenLink" Margin="0,0,8,8" />
                    <Button Content="Noxde's dungeon list" Tag="https://www.nexusmods.com/bloodborne/mods/121"
                            Click="OnOpenLink" Margin="0,0,8,8" />
                    <Button Content="shadPS4" Tag="https://shadps4.net" Click="OnOpenLink" Margin="0,0,8,8" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="Cancel" Click="OnCancel" />
            <Button Content="Save" Click="OnSave" />
        </StackPanel>
    </StackPanel>
</Window>
