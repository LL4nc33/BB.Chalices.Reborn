<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="using:BB.Chalices.Services"
        x:Class="BB.Chalices.App.BackupWindow"
        Width="660" Height="480"
        WindowStartupLocation="CenterOwner"
        RequestedThemeVariant="Dark"
        FontFamily="{DynamicResource GothicFont}"
        Background="{DynamicResource BgBase}"
        Icon="/Assets/favicon.png"
        Title="Backups">

    <Grid Margin="22" RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="Backups" FontSize="22" FontWeight="Bold"
                   Foreground="{DynamicResource Parchment}" Margin="0,0,0,12" />

        <Border Grid.Row="1" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource Edge}" BorderThickness="1">
            <Grid>
                <ListBox x:Name="BackupList" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="services:BackupInfo">
                            <StackPanel Margin="2,3">
                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource Parchment}" />
                                <TextBlock Text="{Binding Notes}" FontSize="11" Foreground="{DynamicResource ParchmentDim}"
                                           IsVisible="{Binding Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock x:Name="EmptyHint"
                           Text="No backups yet. Use &quot;Back up now&quot; or enable auto-backup in Settings."
                           Foreground="{DynamicResource ParchmentDim}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="24"
                           IsVisible="False" IsHitTestVisible="False" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,12,0,0">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                <Button x:Name="BackupNowButton" Content="Back up now" Click="OnCreate"
                        ToolTip.Tip="Create a backup of the current save" />
                <Button Content="Restore selected" Click="OnRestore"
                        IsEnabled="{Binding #BackupList.SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                        ToolTip.Tip="Replace the current save with the selected backup (the current state is backed up first)" />
                <Button Content="Delete" Click="OnDelete"
                        IsEnabled="{Binding #BackupList.SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                        ToolTip.Tip="Delete the selected backup" />
                <Button Content="Open folder" Click="OnOpenFolder"
                        ToolTip.Tip="Open the backup folder" />
            </StackPanel>
            <Button Grid.Column="2" Content="Close" Click="OnClose" />
        </Grid>
    </Grid>
</Window>
