<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BB.Chalices.ViewModels"
        x:Class="BB.Chalices.App.AdvancedWindow"
        x:DataType="vm:MainViewModel"
        Width="720" Height="680" MinWidth="640" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        RequestedThemeVariant="Dark"
        FontFamily="{DynamicResource GothicFont}"
        Background="{DynamicResource BgBase}"
        Icon="/Assets/favicon.png"
        Title="Advanced field editor">

    <Grid Margin="22" RowDefinitions="Auto,*,Auto,Auto">
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Advanced field editor" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource Parchment}" />
            <TextBlock Text="{Binding SelectedSlotType, StringFormat='Editing slot: {0}'}"
                       Foreground="{DynamicResource BloodBright}" />
            <TextBlock Text="Each headstone field as raw hex. A change applies once it is the right length."
                       FontSize="12" Foreground="{DynamicResource ParchmentDim}" Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource Edge}"
                BorderThickness="1" Padding="14">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Fields}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:HeadstoneFieldViewModel">
                            <Grid ColumnDefinitions="180,96,*" Margin="0,4">
                                <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Parchment}" />
                                <TextBlock Grid.Column="1" Text="{Binding OffsetLabel}" VerticalAlignment="Center"
                                           FontSize="11" Foreground="{DynamicResource ParchmentDim}" />
                                <TextBox Grid.Column="2" Text="{Binding Hex}"
                                         FontFamily="Cascadia Mono,Consolas,Menlo,monospace" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource BgBase}" BorderBrush="{DynamicResource Edge}"
                BorderThickness="1" Margin="0,12,0,0" Padding="12,10">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="170">
                <SelectableTextBlock Text="{Binding SlotHexDump}"
                                     FontFamily="Cascadia Mono,Consolas,Menlo,monospace" FontSize="12"
                                     Foreground="{DynamicResource Parchment}" />
            </ScrollViewer>
        </Border>

        <Button Grid.Row="3" Content="Close" Click="OnClose" HorizontalAlignment="Right" Margin="0,12,0,0" />
    </Grid>
</Window>
